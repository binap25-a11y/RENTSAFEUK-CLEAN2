[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "PUT", "POST", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Content-Length",
      "Origin",
      "x-goog-resumable",
      "x-goog-meta-origin",
      "x-firebase-gcs-version"
    ],
    "maxAgeSeconds": 3600
  }
]
