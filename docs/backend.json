
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the profile of a landlord or property manager.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["landlord", "agent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property asset.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string", "description": "UID of the primary verified tenant." },
        "activeTenantUids": { "type": "array", "items": { "type": "string" }, "description": "Array of verified tenant UIDs for shared access." },
        "tenantEmail": { "type": "string", "description": "Registered email for identity handshake." },
        "tenantEmails": { "type": "array", "items": { "type": "string" }, "description": "Registry of authorized emails for discovery." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "propertyType": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "landlordId", "address", "status"]
    },
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a resident identity linked to a property.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Firebase UID after portal handshake." },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "verified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "joinedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "landlordId", "propertyId", "email"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Central user registry for landlords and tenants."
        }
      },
      {
        "path": "/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "description": "Property asset records with denormalized authorization keys."
        }
      },
      {
        "path": "/tenants/{tenantId}",
        "definition": {
          "entityName": "Tenant",
          "description": "Tenant registry records used for portal discovery."
        }
      }
    ]
  }
}
