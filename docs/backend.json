
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Root landlord identity.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Managed rental asset.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "address", "propertyType", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Resident profile.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date" },
        "tenancyEndDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "name", "email"]
    },
    "TenantScreening": {
      "title": "TenantScreening",
      "type": "object",
      "description": "Pre-tenancy audit record.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "screeningDate": { "type": "string", "format": "date-time" },
        "overallNotes": { "type": "string" }
      },
      "required": ["id", "userId", "tenantId", "screeningDate"]
    },
    "PreTenancyChecklist": {
      "title": "PreTenancyChecklist",
      "type": "object",
      "description": "Compliance checklist before move-in.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "tenantId"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "title", "status"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "fileUrl": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "title"]
    },
    "RentPayment": {
      "title": "RentPayment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "year", "month", "status"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "amount", "date"]
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "type", "status"]
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "name", "trade", "phone"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "senderId", "content"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "Landlord identity."
    },
    "/userProfiles/{userId}/contractors/{contractorId}": {
      "schema": "#/entities/Contractor",
      "description": "Vendor directory."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": "#/entities/Property",
      "description": "Owned asset."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": "#/entities/Tenant",
      "description": "Resident."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}": {
      "schema": "#/entities/TenantScreening",
      "description": "Audit record."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/checklists/{checklistId}": {
      "schema": "#/entities/PreTenancyChecklist",
      "description": "Compliance checklist."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": "#/entities/MaintenanceLog",
      "description": "Repair audit."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}": {
      "schema": "#/entities/Document",
      "description": "Compliance doc."
    },
    "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}": {
      "schema": "#/entities/RentPayment",
      "description": "Ledger entry."
    },
    "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Financial outgoing."
    },
    "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}": {
      "schema": "#/entities/Inspection",
      "description": "Condition report."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Direct communication."
    }
  }
}
