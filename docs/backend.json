
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Landlord profile root containing session and display settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "idleTimeoutMinutes": { "type": "number", "default": 30 }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "Physical real estate unit managed by a landlord.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "address", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "A tenant assigned to a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "rentDueDay": { "type": "number" },
        "monthlyRent": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "name", "email", "status"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "Recorded repair issue reported by tenant or landlord.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "contractorName": { "type": "string" },
        "estimatedCost": { "type": "number" }
      },
      "required": ["id", "userId", "propertyId", "title", "status", "priority"]
    },
    "Document": {
      "title": "Document",
      "description": "Compliance or legal file record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "documentType", "expiryDate"]
    },
    "Message": {
      "title": "Message",
      "description": "Secure communication item in a tenant thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Profile root."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Rental units."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": { "$ref": "#/entities/Tenant" },
      "description": "Tenant assignment records."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": { "$ref": "#/entities/MaintenanceLog" },
      "description": "Repair logs."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Legal docs."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{msgId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages."
    }
  }
}
