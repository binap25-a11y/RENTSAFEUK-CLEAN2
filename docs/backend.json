
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the RentSafeUK application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "idleTimeoutMinutes": { "type": "number" },
        "createdDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdDate"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string" },
        "status": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "monthlyRent": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "ownerId", "address", "propertyType", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantUid": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "telephone": { "type": "string" },
        "status": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "reportedBy": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" }
      }
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "expenseType": { "type": "string" }
      }
    },
    "RentPayment": {
      "title": "RentPayment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "description": "Root user profile." }
      },
      {
        "path": "/userProfiles/{userId}/contractors/{contractorId}",
        "definition": { "entityName": "Contractor", "description": "Landlord directory of contractors." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}",
        "definition": { "entityName": "Property", "description": "User properties." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}",
        "definition": { "entityName": "Tenant", "description": "Property tenants." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}",
        "definition": { "entityName": "MaintenanceLog", "description": "Property maintenance records." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}",
        "definition": { "entityName": "Inspection", "description": "Property inspection reports." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense", "description": "Property financial expenses." }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}",
        "definition": { "entityName": "RentPayment", "description": "Rent collection ledger." }
      }
    ]
  }
}
