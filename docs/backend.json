{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Landlord or Property Manager profile. Stores settings and identity mapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "idleTimeoutMinutes": { "type": "number", "default": 30 }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "Physical real estate unit managed by a landlord.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "address", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "A resident associated with a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "rentDueDay": { "type": "number" },
        "monthlyRent": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "lastReminderSent": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "name", "email", "status"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "Recorded repair or maintenance issue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "otherCategoryDetails": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "contractorPhone": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "status", "priority"]
    },
    "RentPayment": {
      "title": "RentPayment",
      "description": "Monthly rent collection tracker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Partially Paid", "Unpaid", "Pending"] },
        "amountPaid": { "type": "number" },
        "expectedAmount": { "type": "number" }
      },
      "required": ["userId", "propertyId", "year", "month", "status"]
    },
    "Checklist": {
      "title": "Checklist",
      "description": "Pre-tenancy compliance checklist for residents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" },
        "beforeTenancy": { "type": "object" },
        "deposit": { "type": "object" },
        "atMoveIn": { "type": "object" },
        "optional": { "type": "object" }
      },
      "required": ["id", "userId", "propertyId", "tenantId"]
    },
    "Inspection": {
      "title": "Inspection",
      "description": "Property condition inspection report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string", "enum": ["Single-Let", "HMO"] },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Cancelled"] },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" },
        "safety": { "type": "object" },
        "interior": { "type": "object" },
        "followUp": { "type": "object" }
      },
      "required": ["id", "userId", "propertyId", "type", "status"]
    },
    "Contractor": {
      "title": "Contractor",
      "description": "Trusted tradesperson directory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "name", "trade", "phone", "status"]
    },
    "Document": {
      "title": "Document",
      "description": "Legal or compliance file record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "documentType"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Financial outgoing record for tax auditing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "date", "expenseType", "amount"]
    },
    "Message": {
      "title": "Message",
      "description": "Secure communication between landlord and resident.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Landlord profile root."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Rental units."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": { "$ref": "#/entities/Tenant" },
      "description": "Assigned residents."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": { "$ref": "#/entities/MaintenanceLog" },
      "description": "Property repairs."
    },
    "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}": {
      "schema": { "$ref": "#/entities/RentPayment" },
      "description": "Financial ledger."
    },
    "/userProfiles/{userId}/properties/{propertyId}/checklists/{checklistId}": {
      "schema": { "$ref": "#/entities/Checklist" },
      "description": "Pre-tenancy checklists."
    },
    "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}": {
      "schema": { "$ref": "#/entities/Inspection" },
      "description": "Property inspection reports."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Compliance documents."
    },
    "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Property expenses."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Secure messages."
    },
    "/userProfiles/{userId}/contractors/{contractorId}": {
      "schema": { "$ref": "#/entities/Contractor" },
      "description": "Contractor contacts."
    }
  }
}
