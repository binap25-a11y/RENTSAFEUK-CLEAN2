{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["landlord", "agent", "tenant"] },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "address": { "type": "object" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Tenancy": {
      "title": "Tenancy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "email": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "landlordId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/properties/{propertyId}", "definition": { "entityName": "Property" } },
      { "path": "/tenants/{tenantId}", "definition": { "entityName": "Tenancy" } },
      { "path": "/messages/{messageId}", "definition": { "entityName": "Message" } },
      { "path": "/repairs/{repairId}", "definition": { "description": "Maintenance requests" } },
      { "path": "/expenses/{expenseId}", "definition": { "description": "Financial outgoings" } },
      { "path": "/rentPayments/{paymentId}", "definition": { "description": "Income ledger" } },
      { "path": "/documents/{documentId}", "definition": { "description": "Compliance vault" } },
      { "path": "/contractors/{contractorId}", "definition": { "description": "Tradespeople directory" } }
    ]
  }
}
