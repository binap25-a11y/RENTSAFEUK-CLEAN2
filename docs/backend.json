
{
  "entities": {
    "User": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile data stored in Firestore.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property managed within the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Property entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this property."
        },
        "address": {
          "type": "object",
          "description": "The structured address of the property.",
          "properties": {
            "nameOrNumber": {
              "type": "string",
              "description": "The name or number of the building/property."
            },
            "street": {
              "type": "string",
              "description": "The street address."
            },
            "city": {
              "type": "string",
              "description": "The city or town."
            },
            "county": {
              "type": "string",
              "description": "The county."
            },
            "postcode": {
              "type": "string",
              "description": "The postcode."
            }
          },
          "required": [
            "street",
            "city",
            "postcode"
          ]
        },
        "propertyType": {
          "type": "string",
          "description": "Type of property (e.g., flat, house, bungalow, maisonette, studio, HMO)."
        },
        "status": {
          "type": "string",
          "description": "Status of the property (e.g., vacant, occupied, under maintenance)."
        },
        "bedrooms": {
          "type": "number",
          "description": "Number of bedrooms in the property."
        },
        "bathrooms": {
          "type": "number",
          "description": "Number of bathrooms in the property."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the primary property image."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the property."
        },
        "purchasePrice": {
          "type": "number",
          "description": "The initial purchase price of the property."
        },
        "currentValuation": {
          "type": "number",
          "description": "The most recent estimated market value."
        },
        "tenancy": {
          "type": "object",
          "description": "Financial details related to the property's tenancy.",
          "properties": {
            "monthlyRent": {
              "type": "number",
              "description": "The monthly rent amount."
            },
            "depositAmount": {
              "type": "number",
              "description": "The total security deposit amount held."
            },
            "depositScheme": {
              "type": "string",
              "description": "The name of the deposit protection scheme used."
            }
          }
        }
      },
      "required": [
        "id",
        "ownerId",
        "address",
        "propertyType",
        "status",
        "bedrooms",
        "bathrooms"
      ]
    },
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant renting a property.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Tenant entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns the property associated with this tenant."
        },
        "propertyId": {
          "type": "string",
          "description": "The ID of the property this tenant is associated with."
        },
        "name": {
          "type": "string",
          "description": "Name of the tenant."
        },
        "email": {
          "type": "string",
          "description": "Email address of the tenant.",
          "format": "email"
        },
        "telephone": {
          "type": "string",
          "description": "Telephone number of the tenant."
        },
        "monthlyRent": {
          "type": "number",
          "description": "The agreed monthly rent amount for this tenant."
        },
        "tenancyStartDate": {
          "type": "string",
          "description": "Start date of the tenancy.",
          "format": "date-time"
        },
        "tenancyEndDate": {
          "type": "string",
          "description": "End date of the tenancy.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the tenant or tenancy."
        },
        "status": {
          "type": "string",
          "description": "The status of the tenant (e.g., Active, Archived)."
        }
      },
      "required": [
        "ownerId",
        "propertyId",
        "name",
        "email",
        "telephone",
        "tenancyStartDate"
      ]
    },
    "MaintenanceLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MaintenanceLog",
      "type": "object",
      "description": "Represents a maintenance log entry for a property.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MaintenanceLog entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this maintenance log."
        },
        "propertyId": {
          "type": "string",
          "description": "Reference to Property."
        },
        "title": {
          "type": "string",
          "description": "A concise title for the maintenance issue."
        },
        "description": {
          "type": "string",
          "description": "Description of the maintenance issue."
        },
        "category": {
          "type": "string",
          "description": "The category of the maintenance issue."
        },
        "priority": {
          "type": "string",
          "description": "Priority level of the maintenance issue."
        },
        "reportedBy": {
          "type": "string",
          "description": "Name of the person who reported the issue."
        },
        "reportedDate": {
          "type": "string",
          "description": "Date when the maintenance issue was reported.",
          "format": "date-time"
        },
        "contractorName": {
          "type": "string",
          "description": "Name of the assigned contractor."
        },
        "contractorPhone": {
          "type": "string",
          "description": "Phone number of the assigned contractor."
        },
        "scheduledDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the work is scheduled for."
        },
        "estimatedCost": {
          "type": "number",
          "description": "The estimated cost of the repair."
        },
        "photoUrls": {
          "type": "array",
          "description": "An array of URLs for photos of the maintenance issue.",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the maintenance log."
        },
        "status": {
          "type": "string",
          "description": "The current status of the maintenance task (e.g., Open, In Progress, Complete)."
        }
      },
      "required": [
        "ownerId",
        "propertyId",
        "title",
        "category",
        "priority",
        "reportedDate",
        "status"
      ]
    },
    "Inspection": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inspection",
      "type": "object",
      "description": "Represents a scheduled inspection for a property.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Inspection entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this inspection."
        },
        "propertyId": {
          "type": "string",
          "description": "Reference to Property. (Relationship: Property 1:N Inspection)"
        },
        "scheduledDate": {
          "type": "string",
          "description": "Date and time the inspection is scheduled for.",
          "format": "date-time"
        },
        "type": {
          "type": "string",
          "description": "The type of inspection (e.g., Single-Let, HMO)."
        },
        "status": {
          "type": "string",
          "description": "The status of the inspection (e.g., Scheduled, Completed)."
        },
        "notes": {
          "type": "string",
          "description": "Notes about the inspection"
        }
      },
      "required": [
        "id",
        "ownerId",
        "propertyId",
        "scheduledDate",
        "type",
        "status"
      ]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Represents a document associated with a property.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Document entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        },
        "propertyId": {
          "type": "string",
          "description": "Reference to Property. (Relationship: Property 1:N Document)"
        },
        "title": {
          "type": "string",
          "description": "Title of the document."
        },
        "documentType": {
          "type": "string",
          "description": "Type of the document (e.g. Tenancy Agreement, EPC)."
        },
        "issueDate": {
          "type": "string",
          "description": "Date the document was issued.",
          "format": "date-time"
        },
        "expiryDate": {
          "type": "string",
          "description": "Date the document expires.",
          "format": "date-time"
        },
        "fileUri": {
          "type": "string",
          "description": "URI of the document file.",
          "format": "uri"
        },
        "fileName": {
          "type": "string",
          "description": "The original name of the uploaded file."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the document."
        }
      },
      "required": [
        "id",
        "ownerId",
        "propertyId",
        "title",
        "documentType",
        "issueDate",
        "expiryDate"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents an expense related to a property.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Expense entity."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this expense log."
        },
        "propertyId": {
          "type": "string",
          "description": "Reference to Property. (Relationship: Property 1:N Expense)"
        },
        "date": {
          "type": "string",
          "description": "Date the expense was incurred.",
          "format": "date-time"
        },
        "expenseType": {
          "type": "string",
          "description": "Category of the expense (e.g., Repairs, Utilities)."
        },
        "amount": {
          "type": "number",
          "description": "The cost of the expense."
        },
        "paidBy": {
          "type": "string",
          "description": "Who paid for the expense (e.g., Landlord, Tenant)."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the expense."
        }
      },
      "required": [
        "id",
        "ownerId",
        "propertyId",
        "date",
        "expenseType",
        "amount",
        "paidBy"
      ]
    },
    "RentPayment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RentPayment",
      "type": "object",
      "description": "Represents a rent payment record for a specific month for a property.",
      "properties": {
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this rent payment record."
        },
        "year": {
          "type": "number",
          "description": "The year of the rent payment."
        },
        "month": {
          "type": "string",
          "description": "The month of the rent payment (e.g., 'January')."
        },
        "status": {
          "type": "string",
          "description": "The payment status.",
          "enum": [
            "Paid",
            "Partially Paid",
            "Unpaid",
            "Pending"
          ]
        },
        "amountPaid": {
          "type": "number",
          "description": "The amount actually paid for the month."
        },
        "expectedAmount": {
          "type": "number",
          "description": "The rent amount expected for the month."
        }
      },
      "required": [
        "ownerId",
        "year",
        "month",
        "status",
        "expectedAmount"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "user",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Collection to store user-related data."
        }
      },
      {
        "path": "/tenants/{tenantId}",
        "definition": {
            "entityName": "Tenant",
            "schema": { "$ref": "#/backend/entities/Tenant" },
            "description": "Top-level collection to store all tenant information."
        }
      },
      {
        "path": "/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": {
            "$ref": "#/backend/entities/Property"
          },
          "description": "Collection to store rental property information."
        }
      },
      {
        "path": "/properties/{propertyId}/maintenanceLogs/{maintenanceLogId}",
        "definition": {
          "entityName": "MaintenanceLog",
          "schema": {
            "$ref": "#/backend/entities/MaintenanceLog"
          },
          "description": "Subcollection to store maintenance logs for each property."
        }
      },
      {
        "path": "/properties/{propertyId}/inspections/{inspectionId}",
        "definition": {
          "entityName": "Inspection",
          "schema": {
            "$ref": "#/backend/entities/Inspection"
          },
          "description": "Subcollection to store inspection schedules for each property."
        }
      },
      {
        "path": "/properties/{propertyId}/documents/{documentId}",
        "definition": {
          "entityName": "Document",
          "schema": {
            "$ref": "#/backend/entities/Document"
          },
          "description": "Subcollection to store documents related to each property."
        }
      },
      {
        "path": "/properties/{propertyId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Subcollection to store expenses for each property."
        }
      },
      {
        "path": "/properties/{propertyId}/rentPayments/{rentPaymentId}",
        "definition": {
          "entityName": "RentPayment",
          "schema": {
            "$ref": "#/backend/entities/RentPayment"
          },
          "description": "Subcollection to store rent payment status."
        }
      }
    ],
    "reasoning": "The structure organizes property management data with properties at the center, using subcollections for specific event logs while keeping tenants at the top level for robust querying."
  }
}
