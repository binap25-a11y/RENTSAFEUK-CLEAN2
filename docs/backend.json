{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["landlord", "agent", "tenant"] },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "tenantEmail": { "type": "string" },
        "activeTenantUids": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "object" },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Tenancy": {
      "title": "Tenancy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "verified": { "type": "boolean" },
        "name": { "type": "string" },
        "telephone": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "landlordId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Repair": {
      "title": "Repair",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "documentType": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "expiryDate": { "type": "string", "format": "date" },
        "fileUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Landlord & Agent Profiles" },
    "/residents/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Resident Access Records" },
    "/properties/{propertyId}": { "schema": { "$ref": "#/backend/entities/Property" }, "description": "Asset registry" },
    "/tenants/{tenantId}": { "schema": { "$ref": "#/backend/entities/Tenancy" }, "description": "Resident registry" },
    "/messages/{messageId}": { "schema": { "$ref": "#/backend/entities/Message" }, "description": "Private communication channel" },
    "/repairs/{repairId}": { "schema": { "$ref": "#/backend/entities/Repair" }, "description": "Maintenance audit trail" },
    "/documents/{documentId}": { "schema": { "$ref": "#/backend/entities/Document" }, "description": "Compliance vault" }
  }
}