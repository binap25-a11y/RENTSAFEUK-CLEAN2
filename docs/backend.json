
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the application, linked to their authentication ID.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property managed by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Owner identifier." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string" },
        "status": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "address", "propertyType", "status"]
    },
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Stores details for a resident in a property.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date" },
        "tenancyEndDate": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "name", "email", "tenancyStartDate"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "contractorPhone": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string", "format": "uri" },
        "notes": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord ID" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "notes": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "UserProfile", "description": "Root user identity." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}", "definition": { "entityName": "Property", "description": "Owned asset." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}", "definition": { "entityName": "Tenant", "description": "Assigned resident." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}", "definition": { "entityName": "Message", "description": "Secure communication." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}", "definition": { "entityName": "TenantScreening", "description": "Pre-tenancy audit." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}", "definition": { "entityName": "MaintenanceLog", "description": "Repair audit." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}", "definition": { "entityName": "Expense", "description": "Financial record." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}", "definition": { "entityName": "Document", "description": "Legal/Safety compliance doc." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}", "definition": { "entityName": "Inspection", "description": "Condition report." } },
      { "path": "/userProfiles/{userId}/contractors/{contractorId}", "definition": { "entityName": "Contractor", "description": "Tradesperson directory." } }
    ]
  }
}
