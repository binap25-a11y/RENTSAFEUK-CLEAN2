
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the application, linked to their authentication ID.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property managed by a landlord.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "address", "propertyType", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Stores details for a resident in a property.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date" },
        "tenancyEndDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "name", "email"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "contractorPhone": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "notes": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "propertyId", "title", "category", "priority", "status"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "date", "expenseType", "amount"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "documentType"]
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Landlord identifier." },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] }
      },
      "required": ["id", "userId", "name", "trade", "phone"]
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "completedDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "type", "status"]
    },
    "Checklist": {
      "title": "Checklist",
      "type": "object",
      "description": "Pre-tenancy legal and practical checks.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "tenantId"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "Root user identity."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": "#/entities/Property",
      "description": "Owned asset."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": "#/entities/Tenant",
      "description": "Assigned resident."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}": {
      "schema": { "title": "Screening", "type": "object", "properties": { "id": { "type": "string" } } },
      "description": "Applicant vetting."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}": {
      "schema": { "title": "Message", "type": "object", "properties": { "id": { "type": "string" } } },
      "description": "Secure communication."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": "#/entities/MaintenanceLog",
      "description": "Repair audit."
    },
    "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Financial record."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}": {
      "schema": "#/entities/Document",
      "description": "Legal/Safety compliance doc."
    },
    "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}": {
      "schema": "#/entities/Inspection",
      "description": "Condition report."
    },
    "/userProfiles/{userId}/properties/{propertyId}/checklists/{checklistId}": {
      "schema": "#/entities/Checklist",
      "description": "Onboarding audit."
    },
    "/userProfiles/{userId}/contractors/{contractorId}": {
      "schema": "#/entities/Contractor",
      "description": "Tradesperson directory."
    }
  }
}
