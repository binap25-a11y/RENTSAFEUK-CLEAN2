{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile and application preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "Represents a rental unit in the portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" }
      },
      "required": ["id", "userId", "address", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Resident record for a specific property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date" },
        "tenancyEndDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Archived"] }
      },
      "required": ["id", "userId", "propertyId", "name", "email"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "Audit record of repairs and issues.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "contractorName": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "status"]
    },
    "RentPayment": {
      "title": "RentPayment",
      "description": "Individual monthly rent collection record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Partially Paid", "Unpaid", "Pending"] },
        "expectedAmount": { "type": "number" },
        "amountPaid": { "type": "number" }
      },
      "required": ["userId", "propertyId", "year", "month", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}", "definition": { "entityName": "Property" } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}", "definition": { "entityName": "Tenant" } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}", "definition": { "description": "Tenant screening checklist and audit." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}", "definition": { "description": "Secure tenant-landlord communication." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}", "definition": { "entityName": "MaintenanceLog" } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}", "definition": { "description": "Field inspection report." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/documents/{documentId}", "definition": { "description": "Compliance certificate or agreement." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}", "definition": { "description": "Asset-linked financial outgoing." } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}", "definition": { "entityName": "RentPayment" } },
      { "path": "/userProfiles/{userId}/properties/{propertyId}/checklists/{checklistId}", "definition": { "description": "Pre-tenancy compliance checklist." } },
      { "path": "/userProfiles/{userId}/contractors/{contractorId}", "definition": { "description": "Saved trade contact details." } }
    ]
  }
}
