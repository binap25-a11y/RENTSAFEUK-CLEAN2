
{
  "entities": {
    "User": {
      "description": "System users (landlords, agents, and tenants).",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "agent", "tenant"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "idleTimeoutMinutes": { "type": "number" }
      }
    },
    "Property": {
      "description": "Rental property assets.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string" },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "monthlyRent": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Tenant": {
      "description": "Tenant records linking users to properties.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The tenant's unique identity key" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "verified": { "type": "boolean" },
        "joinedDate": { "type": "string", "format": "date-time" }
      }
    },
    "Repair": {
      "description": "Maintenance request audit logs.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "priority": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "photoUrls": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "Global account registry" },
    "properties/{propertyId}": { "schema": "Property", "description": "Flat property registry" },
    "tenants/{tenantId}": { "schema": "Tenant", "description": "Flat tenancy registry" },
    "repairs/{repairId}": { "schema": "Repair", "description": "Audit trail for maintenance" },
    "documents/{docId}": { "schema": "Property", "description": "Compliance document registry" },
    "messages/{msgId}": { "schema": "Tenant", "description": "Secure messaging ledge" },
    "expenses/{expenseId}": { "schema": "Property", "description": "Financial outgoing ledger" },
    "inspections/{inspectionId}": { "schema": "Property", "description": "Property audit records" },
    "contractors/{contractorId}": { "schema": "User", "description": "Tradespeople directory" },
    "rentPayments/{paymentId}": { "schema": "Tenant", "description": "Rent collection ledger" },
    "checklists/{checklistId}": { "schema": "Tenant", "description": "Legal pre-tenancy audits" },
    "screenings/{screeningId}": { "schema": "Tenant", "description": "Tenant vetting records" }
  }
}
