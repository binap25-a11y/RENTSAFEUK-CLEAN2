
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Landlord profile storing preferences and management defaults.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number", "default": 30 }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "A rental asset in the landlord's portfolio.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      }
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Resident details and tenancy terms.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "default": "Active" },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceRequest": {
      "title": "MaintenanceRequest",
      "type": "object",
      "description": "Issue report logged by landlord or tenant.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "contractorPhone": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Financial outgoing record for property operations.",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "description": "Property condition report.",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "Compliance or legal document record.",
      "properties": {
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "fileUrl": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "description": "Service provider contact details.",
      "properties": {
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Root landlord profile."
        }
      },
      {
        "path": "/userProfiles/{userId}/contractors/{contractorId}",
        "definition": {
          "entityName": "Contractor",
          "schema": { "$ref": "#/backend/entities/Contractor" },
          "description": "Directory of tradespeople."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": { "$ref": "#/backend/entities/Property" },
          "description": "Rental property document."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}",
        "definition": {
          "entityName": "Tenant",
          "schema": { "$ref": "#/backend/entities/Tenant" },
          "description": "Tenant profile nested under property."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}",
        "definition": {
          "entityName": "MaintenanceRequest",
          "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
          "description": "Repair tracking for property."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": { "$ref": "#/backend/entities/Expense" },
          "description": "Expenditure tracking."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}",
        "definition": {
          "entityName": "Inspection",
          "schema": { "$ref": "#/backend/entities/Inspection" },
          "description": "Property inspection record."
        }
      },
      {
        "path": "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}",
        "definition": {
          "entityName": "Document",
          "schema": { "$ref": "#/backend/entities/Document" },
          "description": "Legal/Compliance file record."
        }
      }
    ]
  }
}
