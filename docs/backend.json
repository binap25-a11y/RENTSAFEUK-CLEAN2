
{
  "entities": {
    "User": {
      "description": "System users (landlords, agents, and tenants).",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "agent", "tenant"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Property": {
      "description": "Rental property assets.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string" },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "monthlyRent": { "type": "number" },
        "imageUrl": { "type": "string" }
      }
    },
    "Tenant": {
      "description": "Tenant records linking users to properties.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The tenant's UID, set after handshake" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" }
      }
    },
    "Repair": {
      "description": "Maintenance requests.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "priority": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "Global user registry" },
    "properties/{propertyId}": { "schema": "Property", "description": "Flat property registry" },
    "tenants/{tenantId}": { "schema": "Tenant", "description": "Flat tenant registry" },
    "repairs/{repairId}": { "schema": "Repair", "description": "Flat maintenance logs" },
    "documents/{docId}": { "schema": "Tenant", "description": "Compliance document registry" },
    "messages/{msgId}": { "schema": "Tenant", "description": "Secure messaging registry" },
    "expenses/{expenseId}": { "schema": "Tenant", "description": "Financial outgoing ledger" },
    "inspections/{inspectionId}": { "schema": "Tenant", "description": "Property inspection registry" },
    "contractors/{contractorId}": { "schema": "Tenant", "description": "Tradespeople directory" },
    "rentPayments/{paymentId}": { "schema": "Tenant", "description": "Income tracking ledger" },
    "checklists/{checklistId}": { "schema": "Tenant", "description": "Pre-tenancy audit logs" },
    "screenings/{screeningId}": { "schema": "Tenant", "description": "Tenant vetting records" }
  }
}
