
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Landlord or Property Manager profile. Stores settings and identity mapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "idleTimeoutMinutes": { "type": "number", "default": 30 }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "Physical real estate unit managed by a landlord.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The owning landlord's UID." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "address", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "A resident currently or previously associated with a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The managing landlord's UID." },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "lastReminderSent": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "propertyId", "name", "email", "status"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "A recorded repair or maintenance issue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "otherCategoryDetails": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedBy": { "type": "string", "description": "UID of reporter (landlord or tenant)." },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "propertyId", "title", "status", "priority"]
    },
    "RentPayment": {
      "title": "RentPayment",
      "description": "Tracking record for monthly rent collection.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Partially Paid", "Unpaid", "Pending"] },
        "expectedAmount": { "type": "number" },
        "amountPaid": { "type": "number" }
      },
      "required": ["userId", "propertyId", "year", "month", "status"]
    },
    "Contractor": {
      "title": "Contractor",
      "description": "A tradesperson or company in the landlord's directory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "name", "trade", "phone", "status"]
    },
    "Document": {
      "title": "Document",
      "description": "A legal or compliance document (EPC, Gas Safety, Agreement).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "propertyId", "title", "documentType", "issueDate", "expiryDate"]
    },
    "TenantScreening": {
      "title": "TenantScreening",
      "description": "Comprehensive pre-tenancy audit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tenantId": { "type": "string" },
        "propertyId": { "type": "string" },
        "screeningDate": { "type": "string", "format": "date-time" },
        "overallNotes": { "type": "string" }
      }
    },
    "Checklist": {
      "title": "Checklist",
      "description": "Pre-tenancy legal and practical compliance checklist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" },
        "beforeTenancy": { "type": "object" },
        "deposit": { "type": "object" },
        "atMoveIn": { "type": "object" },
        "optional": { "type": "object" }
      },
      "required": ["id", "userId", "propertyId", "tenantId"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Root user profile document."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Hierarchical property records."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": { "$ref": "#/entities/Tenant" },
      "description": "Tenants assigned to a specific property."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}": {
      "schema": { "$ref": "#/entities/TenantScreening" },
      "description": "Vetting history for a resident."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": { "$ref": "#/entities/MaintenanceLog" },
      "description": "Maintenance history for a property."
    },
    "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}": {
      "schema": { "$ref": "#/entities/RentPayment" },
      "description": "Rent ledger for a property."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Compliance and legal files."
    },
    "/userProfiles/{userId}/contractors/{contractorId}": {
      "schema": { "$ref": "#/entities/Contractor" },
      "description": "Landlord's contractor directory."
    },
    "/userProfiles/{userId}/properties/{propertyId}/checklists/{checklistId}": {
      "schema": { "$ref": "#/entities/Checklist" },
      "description": "Compliance checklists for a property."
    }
  }
}
