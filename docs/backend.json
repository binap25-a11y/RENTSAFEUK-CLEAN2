{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the profile of a landlord or property manager.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["landlord", "agent", "tenant"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "idleTimeoutMinutes": { "type": "number" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property asset with integrated identity registry.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string", "description": "UID of the primary verified tenant after portal handshake." },
        "activeTenantUids": { "type": "array", "items": { "type": "string" }, "description": "Authorized UIDs for verified shared access." },
        "tenantEmail": { "type": "string", "description": "Primary registered email for verification bridge." },
        "tenantEmails": { "type": "array", "items": { "type": "string" }, "description": "Registry of authorized emails for high-speed discovery." },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "propertyType": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["id", "landlordId", "address", "status"]
    },
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a resident identity record.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Firebase UID linked after portal handshake." },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "verified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Active", "Archived"] },
        "joinedDate": { "type": "string", "format": "date-time" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "inviteSentDate": { "type": "string", "format": "date-time" },
        "lastSyncCheck": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "landlordId", "propertyId", "email"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles for all system roles."
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Central property asset registry."
    },
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Tenant identity registry for discovery."
    },
    "/repairs/{id}": {
      "schema": "object",
      "description": "Shared maintenance tracking ledger."
    },
    "/messages/{id}": {
      "schema": "object",
      "description": "Secure resident-landlord messaging."
    },
    "/documents/{id}": {
      "schema": "object",
      "description": "Compliance document vault."
    },
    "/inspections/{id}": {
      "schema": "object",
      "description": "Property inspection audit reports."
    },
    "/rentPayments/{id}": {
      "schema": "object",
      "description": "Rental collection ledger."
    }
  }
}