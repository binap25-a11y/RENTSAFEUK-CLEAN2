
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Landlord profile storing preferences and management defaults.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "idleTimeoutMinutes": { "type": "number", "default": 30 }
      },
      "required": ["id", "email"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "A rental asset in the landlord's portfolio.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "nameOrNumber": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "county": { "type": "string" },
            "postcode": { "type": "string" }
          },
          "required": ["street", "city", "postcode"]
        },
        "propertyType": { "type": "string", "enum": ["House", "Flat", "HMO", "Bungalow", "Studio"] },
        "status": { "type": "string", "enum": ["Vacant", "Occupied", "Under Maintenance", "Deleted"] },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "imageUrl": { "type": "string" },
        "additionalImageUrls": { "type": "array", "items": { "type": "string" } },
        "purchasePrice": { "type": "number" },
        "currentValuation": { "type": "number" },
        "notes": { "type": "string" },
        "tenancy": {
          "type": "object",
          "properties": {
            "monthlyRent": { "type": "number" },
            "depositAmount": { "type": "number" },
            "depositScheme": { "type": "string" }
          }
        }
      },
      "required": ["ownerId", "address", "propertyType", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Resident details and tenancy terms.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "rentDueDay": { "type": "number" },
        "tenancyStartDate": { "type": "string", "format": "date-time" },
        "tenancyEndDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "default": "Active" },
        "lastReminderSent": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["name", "email", "ownerId", "propertyId", "tenancyStartDate"]
    },
    "MaintenanceRequest": {
      "title": "MaintenanceRequest",
      "type": "object",
      "description": "Issue report logged by landlord or tenant.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "otherCategoryDetails": { "type": "string" },
        "priority": { "type": "string", "enum": ["Emergency", "Urgent", "Routine", "Low"] },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Completed", "Cancelled"] },
        "reportedBy": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date-time" },
        "contractorName": { "type": "string" },
        "contractorPhone": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["title", "category", "priority", "status", "ownerId", "propertyId"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Financial outgoing record for property operations.",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "expenseType": { "type": "string" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "propertyId": { "type": "string" }
      },
      "required": ["amount", "date", "expenseType", "ownerId", "propertyId"]
    },
    "Inspection": {
      "title": "Inspection",
      "type": "object",
      "description": "Property condition report.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "completedDate": { "type": "string", "format": "date-time" },
        "inspectorName": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "summary": { "type": "string" }
      },
      "required": ["type", "status", "scheduledDate", "propertyId", "ownerId"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "Compliance or legal document record.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "documentType": { "type": "string" },
        "fileUrl": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["title", "documentType", "propertyId", "ownerId"]
    },
    "Contractor": {
      "title": "Contractor",
      "type": "object",
      "description": "Service provider contact details.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trade": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["name", "trade", "phone", "ownerId"]
    },
    "RentPayment": {
      "title": "RentPayment",
      "type": "object",
      "description": "Ledger record for monthly rent collection.",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Partially Paid", "Unpaid", "Pending"] },
        "amountPaid": { "type": "number" },
        "expectedAmount": { "type": "number" }
      },
      "required": ["propertyId", "ownerId", "year", "month", "status"]
    },
    "Screening": {
      "title": "Screening",
      "type": "object",
      "description": "Pre-tenancy vetting record.",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "screeningDate": { "type": "string", "format": "date-time" },
        "overallNotes": { "type": "string" }
      },
      "required": ["tenantId", "propertyId", "ownerId", "screeningDate"]
    },
    "Checklist": {
      "title": "Checklist",
      "type": "object",
      "description": "Compliance checklist record.",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "ownerId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "ownerId", "completedDate"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Secure communication record.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Root landlord profile."
    },
    "/userProfiles/{userId}/contractors/{contractorId}": {
      "schema": { "$ref": "#/backend/entities/Contractor" },
      "description": "Directory of tradespeople."
    },
    "/userProfiles/{userId}/properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Rental property document."
    },
    "/userProfiles/{userId}/properties/{propertyId}/checklists/{checklistId}": {
      "schema": { "$ref": "#/backend/entities/Checklist" },
      "description": "Property compliance record."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}": {
      "schema": { "$ref": "#/backend/entities/Tenant" },
      "description": "Tenant profile nested under property."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/screenings/{screeningId}": {
      "schema": { "$ref": "#/backend/entities/Screening" },
      "description": "Vetting record for tenant."
    },
    "/userProfiles/{userId}/properties/{propertyId}/tenants/{tenantId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/Message" },
      "description": "Secure messaging thread."
    },
    "/userProfiles/{userId}/properties/{propertyId}/maintenanceLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
      "description": "Repair tracking for property."
    },
    "/userProfiles/{userId}/properties/{propertyId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/Expense" },
      "description": "Expenditure tracking."
    },
    "/userProfiles/{userId}/properties/{propertyId}/inspections/{inspectionId}": {
      "schema": { "$ref": "#/backend/entities/Inspection" },
      "description": "Property inspection record."
    },
    "/userProfiles/{userId}/properties/{propertyId}/documents/{docId}": {
      "schema": { "$ref": "#/backend/entities/Document" },
      "description": "Legal/Compliance file record."
    },
    "/userProfiles/{userId}/properties/{propertyId}/rentPayments/{paymentId}": {
      "schema": { "$ref": "#/backend/entities/RentPayment" },
      "description": "Monthly rent collection record."
    }
  }
}
