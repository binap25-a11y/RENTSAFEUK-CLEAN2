
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the current user is the landlord of the record
    function isLandlordOf(data) {
      return isSignedIn() && data.landlordId == request.auth.uid;
    }

    // Check if the current user is the tenant linked to the record
    function isTenantOf(data) {
      return isSignedIn() && (
        data.tenantId == request.auth.uid || 
        data.userId == request.auth.uid || 
        (data.email != null && data.email.lower() == request.auth.token.email.lower())
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update, delete: if isLandlordOf(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }

    // --- 4. Portfolio Shared Ledger Data ---
    // (Repairs, Documents, Messages, Expenses, Inspections, Contractors, RentPayments, Checklists, Screenings)
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data) || resource.data.userId == request.auth.uid;
      allow update: if isLandlordOf(resource.data) || isTenantOf(resource.data) || resource.data.userId == request.auth.uid;
      allow delete: if isLandlordOf(resource.data);
    }
  }
}
