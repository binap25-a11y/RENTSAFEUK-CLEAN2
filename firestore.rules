rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v26.0
     * Optimized for high-speed Discovery, Query-Compatible Messaging, and atomic Identity Handshake.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is related to the data via UID or Normalized Email
    function isRelated(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      return isSignedIn() && (
        uid == data.get('landlordId', '') || 
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') || 
          (data.get('tenantEmails', []) is list && email in data.get('tenantEmails', []))
        ))
      );
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Rule-Query Optimization: Allow listing ONLY if filtering by own ID or email
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == resource.data.email
      );
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to update their own verification status if they match the registry email.
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (request.auth.token.email == resource.data.email && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Rule-Query Optimization: Allow listing ONLY if filtering by own ID or tenant email
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.token.email == resource.data.tenantEmail
      );
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their account to the property bridge if they match the registry email.
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (request.auth.token.email == resource.data.tenantEmail && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Optimized for indexed chat queries
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid);
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow get: if isRelated(resource.data);
      allow write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow read: if isRelated(resource.data);
      allow write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow get: if isRelated(resource.data);
      allow write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /contractors/{id} {
      allow list: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /expenses/{id} {
      allow list: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }

    match /checklists/{id} {
      allow list: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
    }
  }
}