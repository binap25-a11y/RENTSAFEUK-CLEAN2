
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full recursive access to their own profile and nested portfolio data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;

      // Portfolio Collections (Properties, Contractors, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Optimized for cross-portfolio discovery and portal access.

    match /{path=**}/tenants/{tenantId} {
      // Discovery for the "Role Check" logic during dashboard initialization.
      // We rely on exact character matching with lowercased email comparison.
      allow list: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower()) ||
        (resource.data.ownerId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower()) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Landlords and assigned tenants can view logs.
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null && resource.data.reportedBy == request.auth.token.email)
      );
      allow create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null)
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn() && (
        (resource.data.senderId == request.auth.uid) ||
        (request.auth.token.email != null)
      );
      allow create: if isSignedIn();
    }

    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/expenses/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/rentPayments/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
    
    match /{path=**}/screenings/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
    
    match /{path=**}/checklists/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
  }
}
