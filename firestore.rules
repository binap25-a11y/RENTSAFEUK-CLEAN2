
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    /**
     * Discovery rules for Tenants.
     * Essential for the 'Role Check' logic which determines if a user should see
     * the Tenant Portal or the Landlord Dashboard.
     */
    match /{path=**}/tenants/{tenantId} {
      // Allows residents to find their own identity records via email match (Discovery query)
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      // Allows landlords to list their own tenants across their portfolio
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // standard get access for both roles
      allow get: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/messages/{messageId} {
      // Allows both landlords and tenants involved in a conversation to list/read messages
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.senderId == request.auth.uid);
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Allows landlords to list their portfolio logs and tenants to list issues they reported
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid || 
        resource.data.reportedBy == request.auth.token.email
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * Recursive portfolio oversight for Landlords.
       * Grants the property owner full read/write access to all nested data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
