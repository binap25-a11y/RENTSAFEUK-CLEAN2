
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Authorized Discovery) ---
    // These rules allow cross-portfolio discovery for residents and landlords.
    // Query constraints must perfectly match these conditions for authorization.
    
    match /{path=**}/tenants/{tenantId} {
      // Rule for Discovery: Filter by authenticated email
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      // Rule for Oversight: Filter by ownership ID
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.senderId == request.auth.uid;
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.reportedBy == request.auth.uid;
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
