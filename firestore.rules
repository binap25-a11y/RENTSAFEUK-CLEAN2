
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user matches the userId provided in the path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full recursive access to their own profile and all nested portfolio data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
      allow list: if false; // Prevent listing of profiles for security

      // Recursive rule for all nested portfolio data (properties, tenants, maintenance, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Critical for Tenant Portal discovery and multi-property reporting.

    match /{path=**}/tenants/{tenantId} {
      // Allow tenants to find their own active record by email
      allow list, get: if isSignedIn() && (
        (resource != null && request.auth.uid == resource.data.ownerId) ||
        (resource != null && request.auth.token.email.lower() == resource.data.email.lower())
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Allow tenants to see/create logs for properties they reside in
      // Verification logic should be handled by application queries comparing email
      allow list, get, create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      // Tenants can view shared documents
      allow list, get: if isSignedIn();
    }

    match /{path=**}/messages/{messageId} {
      // Secure messaging access
      allow list, get, create: if isSignedIn();
    }
  }
}
