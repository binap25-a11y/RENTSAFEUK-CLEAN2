
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if user is a tenant of a property
    // Since we use random IDs, we check if a tenant doc exists with matching email or UID
    // Note: resource.data is used in list/get, request.resource.data in write
    
    match /userProfiles/{userId} {
      allow get, create, update: if isOwner(userId);
      
      // Landlord's Contractor Directory
      match /contractors/{id} {
        allow read, write: if isOwner(userId);
      }

      match /properties/{propertyId} {
        // Read properties if owner
        allow read, write: if isOwner(userId);
        
        // Tenants sub-collection
        match /tenants/{id} { 
          allow read: if isOwner(userId) || (isSignedIn() && (request.auth.uid == id || resource.data.tenantUid == request.auth.uid || resource.data.email == request.auth.token.email));
          allow write: if isOwner(userId);

          match /messages/{mId} {
            allow read, write: if isOwner(userId) || isSignedIn(); // Access checked by parent tenant doc in practice
          }
          
          match /screenings/{sId} {
            allow read, write: if isOwner(userId);
          }
        }
        
        match /maintenanceLogs/{id} { 
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn(); // Allow tenants to report
          allow read: if isSignedIn(); // Allow tenants to see their reported issues
        }

        match /documents/{id} {
          allow read, write: if isOwner(userId);
          allow read: if isSignedIn(); 
        }

        match /inspections/{id} {
          allow read, write: if isOwner(userId);
          allow read: if isSignedIn(); 
        }

        match /expenses/{id} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{id} {
          allow read, write: if isOwner(userId);
          allow read: if isSignedIn();
        }
        
        match /checklists/{id} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Support for Tenant Portal discovery (Collection Group Queries)
    match /{path=**}/tenants/{id} {
      allow list: if isSignedIn(); 
    }
    
    match /{path=**}/maintenanceLogs/{id} {
      allow list: if isSignedIn();
    }
  }
}
