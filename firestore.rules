rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections ---
    match /properties/{propertyId} {
      // Any signed-in user can query properties, but the query must be filtered by ownerId on the client.
      allow list: if isSignedIn();
      // Only the owner can get, create, update, or delete their property.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // Any signed-in user can query tenants, but the query must be filtered by ownerId on the client.
      allow list: if isSignedIn();
      // Only the owner can get, create, update, or delete their tenant records.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      // Any signed-in user can query contractors, but the query must be filtered by ownerId on the client.
      allow list: if isSignedIn();
      // Only the owner can get, create, update, or delete their contractor records.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Subcollection Rules for direct path access ---
    match /properties/{propertyId}/{subcollection}/{docId} {
      // All access requires checking ownership of the parent property.
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // This rule applies to all subcollections under a tenant.
    match /tenants/{tenantId}/{subcollection}/{docId} {
      // All access requires checking ownership of the parent tenant document.
      allow read, write: if get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
  }
}
