rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email == null ? "" : request.auth.token.email.lower();
    }

    // Helper to check if user is the landlord of a document
    function isLandlord(data) {
      return isSignedIn() && data.landlordId == request.auth.uid;
    }

    // Helper to check if user is the tenant of a property
    function isTenantOfProperty(propertyId) {
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      return isSignedIn() && (
        property.tenantId == request.auth.uid ||
        (request.auth.token.email != null && authEmail() in property.tenantEmails)
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in resource.data && authEmail() in resource.data.tenantEmails)
      );
      allow update, delete: if isLandlord(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == authEmail())
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == authEmail())
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 4. Repairs, Documents, Messages, and other ledgers ---
    // Using a more robust catch-all for relational data
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "email" in resource.data && resource.data.email == authEmail()) ||
        (request.auth.token.email != null && "tenantEmail" in resource.data && resource.data.tenantEmail == authEmail()) ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow delete: if isLandlord(resource.data);
    }
  }
}