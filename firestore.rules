/**
 * Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model designed for a multi-tenant property 
 * management application. All data is hierarchically organized and secured under a 
 * user's unique profile path.
 *
 * Data Structure:
 * All application entities (Properties, Tenants, Tenancies, etc.) are stored as 
 * subcollections under `/userProfiles/{userProfileId}/`. This creates a natural 
 * security boundary where a user's UID is the primary key for all data access.
 *
 * collectionGroup Support:
 * To enable cross-portfolio role discovery (identifying if a user is a resident 
 * in any estate), we provide restricted list access to the 'tenants', 'messages', 
 * and 'maintenanceLogs' collection groups. These rules are split into distinct 
 * allow statements to ensure the Firestore query engine can authorize requests 
 * that filter by specific identities (email or UID).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function matchesPath(userProfileId) {
      return request.resource.data.userId == userProfileId;
    }

    function remainsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow get: if isOwner(userProfileId);
      allow list: if false;
      
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userProfileId);

      match /properties/{propertyId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);

        match /maintenanceLogs/{logId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /inspections/{inspectionId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /documents/{documentId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /tenants/{tenantId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);

          match /screenings/{screeningId} {
            allow get, list: if isOwner(userProfileId);
            allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
            allow update: if isExistingOwner(userProfileId) && remainsImmutable();
            allow delete: if isExistingOwner(userProfileId);
          }

          match /messages/{messageId} {
            allow get, list: if isOwner(userProfileId);
            allow create: if isOwner(userProfileId); // landlord sending message
            allow update, delete: if isExistingOwner(userProfileId);
          }
        }

        match /expenses/{expenseId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /rentPayments/{paymentId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }
    }

    // --- collectionGroup Discovery Rules ---
    // These are critical for the Resident Portal.
    // SPLIT RULES: Distinct allow blocks for email discovery vs UID ownership. 
    // This allows the Firestore query engine to successfully authorize restricted list queries.

    match /{path=**}/tenants/{tenantId} {
      // 1. Resident Identity Discovery
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      // 2. Landlord Portfolio Management
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // 3. Direct document access
      allow get: if isSignedIn() && (resource.data.email == request.auth.token.email.lower() || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/messages/{messageId} {
      // 1. Resident/Participant access
      allow list: if isSignedIn() && resource.data.senderId == request.auth.uid;
      // 2. Landlord oversight
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // 3. Direct document access
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.senderId == request.auth.uid);
      // 4. Resident replying
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // 1. Resident discovery (if they reported it)
      allow list: if isSignedIn() && resource.data.reportedBy == request.auth.uid;
      // 2. Landlord discovery
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // 3. Direct document access
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.reportedBy == request.auth.uid);
    }
  }
}