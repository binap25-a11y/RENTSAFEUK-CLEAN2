rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK CORE SECURITY GOVERNANCE
     * Matches application architecture using flat root collections.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.activeTenantUids ||
        userEmail() == resource.data.tenantEmail
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.activeTenantUids ||
        userEmail() == resource.data.tenantEmail
      );
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE AUTHORIZATION BRIDGE: Allows residents to link their accounts
        (userEmail() == resource.data.tenantEmail && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants / Residents Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.query.filters.userId == request.auth.uid ||
        request.query.filters.email == userEmail()
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email == userEmail()
      );
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE AUTHORIZATION BRIDGE
        (resource.data.email == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck', 'lastSyncCheck']))
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance / Repairs ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.query.filters.tenantId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid ||
        request.resource.data.tenantId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
    }

    // --- Resident Communication Hub ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        request.query.filters.tenantId == request.auth.uid ||
        request.query.filters.landlordId == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid &&
        (request.resource.data.tenantId == request.auth.uid || request.resource.data.landlordId == request.auth.uid)
      );
    }

    // --- Financial Ledger (Expenses & Rent) ---
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
    }
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
    }

    // --- Compliance & Audit (Docs, Screenings, Checklists) ---
    match /documents/{id} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.query.filters.propertyId != null // Validated by app code ownership filters
      );
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /screenings/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
    }
    match /checklists/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
    }

    // --- Contractor Directory ---
    match /contractors/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
    }
  }
}
