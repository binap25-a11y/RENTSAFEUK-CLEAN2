/**
 * FIRESTORE SECURITY RULES
 * 
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model using Path-Based Access Modeling.
 * All data is organized hierarchically to ensure that users can only access and modify 
 * their own information.
 * 
 * DATA STRUCTURE:
 * All application data is nested under the `/userProfiles/{userId}` path. 
 * - `/userProfiles/{userId}`: User profile information.
 * - `/userProfiles/{userId}/properties/{propertyId}`: Properties owned by the user.
 * - `/userProfiles/{userId}/properties/{propertyId}/[subcollection]`: Specialized data 
 *   (Tenancies, Images, Logs, etc.) belonging to a specific property.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);

      match /properties/{propertyId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('userId');
        allow delete: if isExistingOwner(userId);

        match /tenants/{tenantId} {
          allow read, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.propertyId == propertyId;
          allow update: if isExistingOwner(userId) && isImmutable('userId') && isImmutable('propertyId');
          allow delete: if isExistingOwner(userId);

          match /screenings/{screeningId} {
            allow read, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.propertyId == propertyId;
            allow update: if isExistingOwner(userId) && isImmutable('userId') && isImmutable('propertyId');
            allow delete: if isExistingOwner(userId);
          }

          match /messages/{messageId} {
            allow read, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.userId == userId;
            allow update: if isExistingOwner(userId) && isImmutable('userId');
            allow delete: if isExistingOwner(userId);
          }
        }

        match /maintenanceLogs/{logId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.propertyId == propertyId;
          allow update: if isExistingOwner(userId) && isImmutable('userId') && isImmutable('propertyId');
          allow delete: if isExistingOwner(userId);
        }

        match /inspections/{inspectionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.propertyId == propertyId;
          allow update: if isExistingOwner(userId) && isImmutable('userId') && isImmutable('propertyId');
          allow delete: if isExistingOwner(userId);
        }

        match /documents/{documentId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.propertyId == propertyId;
          allow update: if isExistingOwner(userId) && isImmutable('userId') && isImmutable('propertyId');
          allow delete: if isExistingOwner(userId);
        }

        match /expenses/{expenseId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && isImmutable('userId');
          allow delete: if isExistingOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && isImmutable('userId');
          allow delete: if isExistingOwner(userId);
        }

        match /checklists/{checklistId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && isImmutable('userId');
          allow delete: if isExistingOwner(userId);
        }
      }

      match /contractors/{contractorId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('userId');
        allow delete: if isExistingOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES (For Cross-Portfolio Discovery) ---

    match /{path=**}/tenants/{tenantId} {
      // Simplified rule for collectionGroup 'tenants' to ensure query optimizer can verify authorization.
      // Direct equality with token email is required for the 'list' query.
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.senderId == request.auth.uid);
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.reportedBy == request.auth.uid);
    }
  }
}
