
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Authorized Discovery) ---
    // These rules allow cross-portfolio discovery for residents and landlords.
    // Separated into distinct allow statements to ensure the Firestore query engine 
    // can verify query authorization statically.
    
    match /{path=**}/tenants/{tenantId} {
      // Allow residents to find their own tenancy via email (standardized to lower case)
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      // Allow landlords to view their own tenants across the entire portfolio
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Get rule for detail view access
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.senderId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.reportedBy == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
