rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      // Users can only read and write their own profile document.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections ---
    match /properties/{propertyId} {
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // --- Subcollections ---
    // A user can read/write a document in a subcollection if they own it.
    // The client queries are responsible for filtering by ownerId for list operations.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
