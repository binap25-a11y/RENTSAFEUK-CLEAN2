
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v8.0
     * Optimized for Static Rule-Query Verification and Role-Based Determinism.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.get("email", "").lower();
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /residents/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      // LANDLORD BRANCH: Provable via landlordId filter
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      
      // RESIDENT BRANCH (UID): Provable via activeTenantUids filter
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('activeTenantUids', []);
      
      // RESIDENT BRANCH (EMAIL): Provable via tenantEmail filter
      allow list: if isSignedIn() && userEmail() != "" && userEmail() in request.query.filters.get('tenantEmail', []);
      
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get("activeTenantUids", []) ||
        resource.data.get("tenantEmail", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes Residents to link UID on first login
        (resource.data.get("tenantEmail", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('userId', []);
      allow list: if isSignedIn() && userEmail() != "" && userEmail() in request.query.filters.get('email', []);
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.get("userId", "") == request.auth.uid ||
        resource.data.get("email", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes UID linking
        (resource.data.get("email", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('tenantId', []);
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('reportedBy', []);
      
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get("reportedBy", "") == request.auth.uid
      );
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('tenantId', []);
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Documents ---
    match /documents/{id} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow list: if isSignedIn() && request.query.filters.has('propertyId');
      
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /expenses/{id} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /rentPayments/{id} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Portfolio Fallbacks ---
    match /contractors/{id} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.get('landlordId', []);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
  }
}
