rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Standardized normalized email helper for query-compatible rules
    function authEmail() {
      return request.auth.token.email == null ? "" : request.auth.token.email.lower();
    }

    function isLandlord(data) {
      return isSignedIn() && data.landlordId == request.auth.uid;
    }

    // Helper to check if user is a verified tenant of a property
    function isTenantOfProperty(propertyId) {
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      return isSignedIn() && (
        property.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in property && authEmail() in property.tenantEmails)
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in resource.data && authEmail() in resource.data.tenantEmails)
      );
      // Allow tenants to sync their tenantId link once during discovery
      allow update: if isLandlord(resource.data) || (
        isSignedIn() && 
        "tenantEmails" in resource.data && 
        authEmail() in resource.data.tenantEmails && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId']) &&
        request.resource.data.tenantId == request.auth.uid
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      // Optimized for high-speed discovery queries
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.email == authEmail()
      );
      // Allow self-link during handshake
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.email == authEmail()
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 4. Ledger Collections (Repairs, Documents, Messages, etc) ---
    // Specifically defined to avoid query-block conflicts
    match /repairs/{id} { allow read, write: if isSignedIn() && (isLandlord(resource.data) || resource.data.tenantId == request.auth.uid || resource.data.email == authEmail() || resource.data.tenantEmail == authEmail() || ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))); }
    match /documents/{id} { allow read, write: if isSignedIn() && (isLandlord(resource.data) || resource.data.tenantId == request.auth.uid || ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))); }
    match /messages/{id} { allow read, write: if isSignedIn() && (isLandlord(resource.data) || resource.data.tenantId == request.auth.uid || resource.data.email == authEmail() || ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))); }
    match /expenses/{id} { allow read, write: if isLandlord(resource.data); }
    match /inspections/{id} { allow read, write: if isLandlord(resource.data) || ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId)); }
    match /contractors/{id} { allow read, write: if isLandlord(resource.data); }
    match /rentPayments/{id} { allow read, write: if isLandlord(resource.data) || resource.data.tenantId == request.auth.uid || ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId)); }
    match /checklists/{id} { allow read, write: if isLandlord(resource.data); }
    match /screenings/{id} { allow read, write: if isLandlord(resource.data); }
  }
}