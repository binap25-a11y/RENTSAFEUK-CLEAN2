rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // USER data can only be read/written by the user themselves
    match /users/{userId} {
      // allow get/update/delete on the user document itself
      allow get, update, delete: if isOwner(userId);
      // allow creation of the user document
      allow create: if isOwner(userId);

      // Rule for GETTING/WRITING individual tenant documents
      match /tenants/{tenantId} {
        allow get, create, update, delete: if isOwner(userId);
        
        // SCREENINGS are owned by the user via the tenant
        match /screenings/{screeningId} {
            allow read, write: if isOwner(userId);
        }
      }
      
      // Rule for LISTING tenants collection
      match /tenants {
        allow list: if isOwner(userId);
      }
    }
    
    // PROPERTIES
    match /properties/{propertyId} {
      // A user can read, update, or delete a property if they are the owner.
      // The `read` permission covers both `get` (single doc) and `list` (queries).
      // For queries, Firestore checks if the query's `where` clause guarantees
      // that this rule will pass for all potential documents.
      allow read, update, delete: if resource.data.ownerId == request.auth.uid;
      
      // A user can create a property if the `ownerId` in the new document
      // matches their own user ID.
      allow create: if request.resource.data.ownerId == request.auth.uid;

      // PROPERTY SUBCOLLECTIONS can only be managed by the property owner
      match /{subcollection}/{docId} {
        allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      }
    }
    
    // CONTRACTORS can only be managed by their owner
    match /contractors/{contractorId} {
       allow read, update, delete: if resource.data.ownerId == request.auth.uid;
       allow create: if request.resource.data.ownerId == request.auth.uid;
    }
  }
}
