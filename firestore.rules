rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      // Users can only read and write their own profile document.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections (Properties, Tenants, Contractors) ---
    match /properties/{propertyId} {
      // A user can read/write a property document if they are the owner.
      // For 'list' operations, the client query MUST filter by ownerId.
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // --- Subcollections ---
    match /properties/{propertyId}/{subcollection}/{docId} {
      // A user can read/write a document in a subcollection if they are the owner.
      // This rule requires that the ownerId is present on all subcollection documents.
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId}/{subcollection}/{docId} {
      // This follows the same pattern as property subcollections.
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
