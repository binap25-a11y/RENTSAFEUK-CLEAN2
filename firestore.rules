rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v15.0
     * Optimized for high-speed Discovery and secure Identity Handshake.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '')
      );
    }

    // DISCOVERY: Allows tenants to identify their record by email token
    function isTenantDiscovery() {
      let email = request.auth.token.email;
      return isSignedIn() && email != null;
    }

    // AUTHORIZED: Validates relationship via UID or verified registry bridge
    function isRelated(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      return isLandlord(data) || (isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') || 
          email in data.get('tenantEmails', [])
        ))
      ));
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // HIGH-SPEED DISCOVERY: Allow listing so performDiscovery() can find the record by email.
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to update their own verification status/UID
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenantDiscovery() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to link their account to the property bridge
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenantDiscovery() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn();
      allow read: if isLandlord(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /checklists/{id} {
      allow list: if isSignedIn();
      allow read: if isLandlord(resource.data);
      allow write: if isLandlord(resource.data);
    }
  }
}
