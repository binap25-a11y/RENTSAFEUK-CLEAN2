
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v22.0
     * Optimized for high-speed query prove-ability and query-rule alignment.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      // Safely retrieve email from token and normalize to lowercase
      return request.auth.token.get('email', '').lower();
    }

    function getUid() {
      return request.auth.uid;
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && getUid() == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Split list rules for query engine optimization
      allow list: if isSignedIn() && resource.data.landlordId == getUid();
      allow list: if isSignedIn() && resource.data.userId == getUid();
      allow list: if isSignedIn() && resource.data.email == getEmail();
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == getUid() || 
        resource.data.userId == getUid() || 
        resource.data.email == getEmail()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID if they match the registry email
      allow update: if isSignedIn() && (
        resource.data.landlordId == getUid() || 
        (resource.data.email == getEmail() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isSignedIn() && resource.data.landlordId == getUid();
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Split list rules for high-speed collection scans alignment
      allow list: if isSignedIn() && resource.data.landlordId == getUid();
      allow list: if isSignedIn() && resource.data.tenantId == getUid();
      allow list: if isSignedIn() && getUid() in resource.data.get('activeTenantUids', []);
      allow list: if isSignedIn() && resource.data.tenantEmail == getEmail();

      allow get: if isSignedIn() && (
        resource.data.landlordId == getUid() || 
        resource.data.tenantId == getUid() || 
        getUid() in resource.data.get('activeTenantUids', []) ||
        resource.data.tenantEmail == getEmail()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID to the property bridge if authorized by email
      allow update: if isSignedIn() && (
        resource.data.landlordId == getUid() || 
        (resource.data.tenantEmail == getEmail() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isSignedIn() && resource.data.landlordId == getUid();
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Split list rules for query optimization
      allow list: if isSignedIn() && resource.data.tenantId == getUid();
      allow list: if isSignedIn() && resource.data.landlordId == getUid();
      
      allow get: if isSignedIn() && (
        resource.data.tenantId == getUid() || 
        resource.data.landlordId == getUid()
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.senderId == getUid() &&
        (request.resource.data.tenantId == getUid() || request.resource.data.landlordId == getUid())
      );
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && resource.data.landlordId == getUid();
      allow list: if isSignedIn() && resource.data.tenantId == getUid();
      allow list: if isSignedIn() && resource.data.reportedBy == getUid();
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == getUid() || 
        resource.data.tenantId == getUid() || 
        resource.data.reportedBy == getUid()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid());
      allow delete: if isSignedIn() && resource.data.landlordId == getUid();
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid() || resource.data.propertyId != null);
      allow read: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid() || resource.data.propertyId != null);
      allow write: if isSignedIn() && resource.data.landlordId == getUid();
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid());
      allow read: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid());
      allow write: if isSignedIn() && resource.data.landlordId == getUid();
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid());
      allow get: if isSignedIn() && (resource.data.landlordId == getUid() || resource.data.tenantId == getUid());
      allow write: if isSignedIn() && resource.data.landlordId == getUid();
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isSignedIn();
    }

    match /expenses/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }

    match /checklists/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }
  }
}
