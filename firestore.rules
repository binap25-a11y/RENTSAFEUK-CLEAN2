rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- User Profile ---
    // Users can only read and write their own document.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
    }

    // --- Properties Collection ---
    match /properties {
      // Any authenticated user can create a property. The app code ensures ownerId is set.
      allow create: if request.auth != null;
      allow list: if request.auth.uid != null;
    }

    match /properties/{propertyId} {
      // Only the owner can get, update, or delete their property.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    // --- Tenants Collection ---
    match /tenants {
       // Any authenticated user can create a tenant. The app code ensures ownerId is set.
      allow create: if request.auth != null;
      allow list: if request.auth.uid != null;
    }

    match /tenants/{tenantId} {
      // Only the owner can get, update, or delete their tenant.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    // --- Contractors Collection ---
    match /contractors {
      // Any authenticated user can create a contractor. The app code ensures ownerId is set.
      allow create: if request.auth != null;
      allow list: if request.auth.uid != null;
    }

    match /contractors/{contractorId} {
      // Only the owner can get, update, or delete their contractor.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    // --- Generic Sub-Collection Rules ---

    // This rule applies to ALL sub-collections under any property.
    // It allows read/write access only if the user owns the parent property document.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // This rule applies to ALL sub-collections under any tenant.
    // It allows read/write access only if the user owns the parent tenant document.
    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
  }
}
