rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANDLORD PROPERTY MANAGEMENT SECURITY MODEL
     * 
     * Core Philosophy:
     * This ruleset enforces a strict User-Ownership model. All application data is 
     * nested under a specific user's profile (/userProfiles/{userId}/...), ensuring 
     * that authorization is derived directly from the URL path for landlords.
     * 
     * Tenant Discovery:
     * The application uses collectionGroup queries to allow tenants to find their 
     * associated property by email. Access is granted based on the email in their 
     * authentication token.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Verifies ownership and existence for destructive operations (update/delete).
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Checks if the user is the tenant associated with the record (by email).
     */
    function isAuthorizedTenant(data) {
      return isSignedIn() && data.email != null && data.email == request.auth.token.email;
    }

    // --- Rules ---

    /**
     * @description Rules for the user's root profile and subcollections.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      /**
       * @description Rules for rental properties managed by a landlord.
       */
      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Allow tenants assigned to this property to read basic details
        allow get: if isSignedIn();

        /**
         * @description Nested subcollections under properties.
         */
        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          // Allow the tenant to read their own identity record
          allow get: if isAuthorizedTenant(resource.data);
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          // Tenants can report issues and view logs for their property
          allow create: if isSignedIn();
          allow get, list: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /checklists/{checklistId} {
          allow read, write: if isOwner(userId);
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
        
        // Messaging for tenancies
        match /tenants/{tenantId}/messages/{messageId} {
           allow read, write: if isOwner(userId) || isSignedIn();
        }
      }

      /**
       * @description Master directory for contractors.
       */
      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Collection Group Rules (CRITICAL for Portal discovery) ---

    /**
     * @description Allows tenants to discover their own record via collectionGroup search.
     * This is what unblocks the "Verification Failed" error in the Tenant Portal.
     */
    match /{path=**}/tenants/{tenantId} {
      // Firestore enforces that the query MUST filter by email for this rule to pass.
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow get: if isSignedIn() && resource.data.email == request.auth.token.email;
    }

    /**
     * @description Allows cross-landlord listing for reported issues and messages.
     */
    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow list: if isSignedIn();
    }
  }
}