
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user matches the userId provided in the path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full recursive access to their own profile and all nested portfolio data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Prevent listing of all profiles

      // Recursive rule for all nested portfolio data (properties, tenants, maintenance, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Essential for role discovery and cross-portfolio discovery.

    match /{path=**}/tenants/{tenantId} {
      // Allow discovery for the "Role Check" and Tenant Portal via email query.
      // We explicitly check for owner matching or email matching to support CG queries.
      allow list, get: if isSignedIn() && (
        (resource.data.email == request.auth.token.email) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Tenants can view/create logs for properties they reside in.
      allow list, get, create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      // Tenants can view shared compliance documents.
      allow list, get: if isSignedIn();
    }

    match /{path=**}/messages/{messageId} {
      // Secure messaging for active tenancies.
      allow list, get, create: if isSignedIn();
    }

    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn();
    }

    match /{path=**}/expenses/{id} {
      allow list, get: if isSignedIn();
    }

    match /{path=**}/rentPayments/{id} {
      allow list, get: if isSignedIn();
    }
  }
}
