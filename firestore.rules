rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v3.0
     * Optimized for high-speed identity discovery and verified Resident Hub handshakes.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Landlord check: verifies if user owns the record or is the landlord of the linked property
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '') || 
        request.auth.uid == data.get('userId', '')
      );
    }

    // Tenant check: authorizes access via UID or verified email handshake
    function isTenant(data) {
      let email = request.auth.token.email;
      return isSignedIn() && (
        request.auth.uid == data.get('tenantId', '') || 
        request.auth.uid == data.get('userId', '') ||
        request.auth.uid in data.get('activeTenantUids', []) ||
        (email != null && email == data.get('email', '')) ||
        (email != null && email == data.get('tenantEmail', '')) ||
        (email != null && (email in data.get('tenantEmails', [])))
      );
    }

    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // IDENTITY DISCOVERY: Allow residents to find their own records via email/UID filter
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      // HANDSHAKE: Allow verified residents to link their UID to the registry record
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      // HANDSHAKE: Allow residents to link their account to the property asset
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'tenantEmail', 'tenantEmails', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Portals & Audit Trails ---
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow get: if isLandlord(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isLandlord(resource.data);
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow get: if isLandlord(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /checklists/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /screenings/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    // --- Catch-all fallback for other sub-collections ---
    match /{path=**} {
      allow read, write: if isSignedIn() && (
        (resource != null && isLandlord(resource.data)) ||
        (request.resource != null && isLandlord(request.resource.data))
      );
    }
  }
}