
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v23.0
     * Optimized for high-speed query prove-ability and query-rule alignment.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      // Safely retrieve email from token and normalize to lowercase
      return request.auth.token.get('email', '').lower();
    }

    function getUid() {
      return request.auth.uid;
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && getUid() == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Consolidated list rule for query engine optimization
      allow list: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('userId', '') == getUid() || 
        resource.data.get('email', '').lower() == getEmail()
      );
      
      allow get: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('userId', '') == getUid() || 
        resource.data.get('email', '').lower() == getEmail()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID if they match the registry email
      allow update: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        (resource.data.get('email', '').lower() == getEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Consolidated list rule for high-speed collection scans alignment
      allow list: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        getUid() in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', '').lower() == getEmail()
      );

      allow get: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        getUid() in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', '').lower() == getEmail()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID to the property bridge if authorized by email
      allow update: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        (resource.data.get('tenantEmail', '').lower() == getEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Consolidated list rule for query engine optimization
      allow list: if isSignedIn() && (
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('landlordId', '') == getUid()
      );
      
      allow get: if isSignedIn() && (
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('landlordId', '') == getUid()
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.senderId == getUid() &&
        (request.resource.data.get('tenantId', '') == getUid() || request.resource.data.get('landlordId', '') == getUid())
      );
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('reportedBy', '') == getUid()
      );
      
      allow get: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('reportedBy', '') == getUid()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.get('landlordId', '') == getUid() || resource.data.get('tenantId', '') == getUid());
      allow delete: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('propertyId') != null
      );
      allow read: if isSignedIn() && (
        resource.data.get('landlordId', '') == getUid() || 
        resource.data.get('tenantId', '') == getUid() || 
        resource.data.get('propertyId') != null
      );
      allow write: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && (resource.data.get('landlordId', '') == getUid() || resource.data.get('tenantId', '') == getUid());
      allow read: if isSignedIn() && (resource.data.get('landlordId', '') == getUid() || resource.data.get('tenantId', '') == getUid());
      allow write: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (resource.data.get('landlordId', '') == getUid() || resource.data.get('tenantId', '') == getUid());
      allow get: if isSignedIn() && (resource.data.get('landlordId', '') == getUid() || resource.data.get('tenantId', '') == getUid());
      allow write: if isSignedIn() && resource.data.get('landlordId', '') == getUid();
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isSignedIn();
    }

    match /expenses/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
      allow read, write: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
      allow read, write: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
    }

    match /checklists/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
      allow read, write: if isSignedIn() && getUid() == resource.data.get('landlordId', '');
    }
  }
}
