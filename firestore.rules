rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- PROFILE ---
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- TOP-LEVEL COLLECTIONS ---
    match /properties/{propertyId} {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid == request.query.where.ownerId;
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }

    match /tenants/{tenantId} {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid == request.query.where.ownerId;
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }
    
    match /contractors/{contractorId} {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid == request.query.where.ownerId;
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }

    // --- SUBCOLLECTIONS ---
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid == request.query.where.ownerId;
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }
    
    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid == request.query.where.ownerId;
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }
  }
}
