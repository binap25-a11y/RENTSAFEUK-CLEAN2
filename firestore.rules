
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user matches the userId provided in the path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full access to their own profile and all nested data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Prevent listing of all landlord profiles

      // Portfolio Collections (Properties, Contractors, etc.)
      match /{collectionName}/{docId} {
        allow read, write: if isOwner(userId);
        
        // Recursive rule for nested resources (tenants, logs, etc.)
        match /{allPaths=**} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // --- COLLECTION GROUP RULES ---
    // These are critical for discovery queries (e.g. "Am I a tenant in any portfolio?")

    match /{path=**}/tenants/{tenantId} {
      // Rule 1: Allow discovery via email for the "Role Check" and Tenant Portal.
      // The query MUST filter by email to be authorized for a tenant.
      allow list: if isSignedIn() && request.auth.token.email != null && resource.data.email == request.auth.token.email;
      
      // Rule 2: Allow landlords to discover their own tenants via collection group if needed.
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Allow get if user is the tenant or the owner
      allow get: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Landlords and assigned tenants can view logs.
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/userProfiles/$(resource.data.ownerId)/properties/$(resource.data.propertyId)/tenants))
      );
      // Tenants can create logs for their property.
      allow create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/userProfiles/$(resource.data.ownerId)/properties/$(resource.data.propertyId)/tenants))
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get, create: if isSignedIn();
    }

    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/expenses/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/rentPayments/{id} {
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/userProfiles/$(resource.data.ownerId)/properties/$(resource.data.propertyId)/tenants))
      );
    }
    
    match /{path=**}/screenings/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
    
    match /{path=**}/checklists/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
  }
}
