rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(docData) {
      return request.auth.uid == docData.ownerId;
    }

    // --- User Profile ---
    match /users/{userId} {
      allow get, update: if request.auth.uid == userId;
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      allow get, update, delete: if isOwner(resource.data);
    }
    match /properties {
      allow create: if isOwner(request.resource.data);
      allow list: if request.auth.uid != null;
    }
    
    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow get, update, delete: if isOwner(resource.data);
    }
    match /tenants {
      allow create: if isOwner(request.resource.data);
      allow list: if request.auth.uid != null;
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow get, update, delete: if isOwner(resource.data);
    }
     match /contractors {
      allow create: if isOwner(request.resource.data);
      allow list: if request.auth.uid != null;
    }

    // --- Sub-Collection Rules ---
    function isParentOwner(parentCollection, parentId) {
        return get(/databases/$(database)/documents/$(parentCollection)/$(parentId)).data.ownerId == request.auth.uid;
    }

    match /properties/{propertyId}/{subcollection}/{docId} {
      allow get, update, delete, create: if isParentOwner('properties', propertyId);
    }
    match /properties/{propertyId}/{subcollection} {
      allow list: if isParentOwner('properties', propertyId);
    }

    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow get, update, delete, create: if isParentOwner('tenants', tenantId);
    }
    match /tenants/{tenantId}/{subcollection} {
      allow list: if isParentOwner('tenants', tenantId);
    }
  }
}
