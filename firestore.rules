/**
 * Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model designed for a multi-tenant property 
 * management application. All data is hierarchically organized and secured under a 
 * user's unique profile path.
 *
 * Data Structure:
 * All application entities (Properties, Tenants, Tenancies, etc.) are stored as 
 * subcollections under `/userProfiles/{userProfileId}/`. This creates a natural 
 * security boundary where a user's UID is the primary key for all data access.
 *
 * Key Security Decisions:
 * 1. Strict Ownership: Access is granted only if the authenticated user's UID 
 *    matches the `{userProfileId}` in the document path.
 * 2. Relational Integrity: On creation, documents must include a `userProfileId` 
 *    field that matches the path, and this field is immutable thereafter.
 * 3. Prototyping Flexibility: While ownership is strictly enforced, the rules 
 *    do not validate the specific schema of content fields, allowing for rapid 
 *    development and iteration of the data model.
 * 4. Structural Segregation: By nesting data under user-specific paths, we avoid 
 *    the risks of collection-group queries exposing data across different users.
 *
 * Denormalization for Authorization:
 * The `userProfileId` is denormalized onto every document. This allows rules to 
 * verify ownership using only the document's own data (`resource.data`) or the 
 * path parameters, ensuring high performance and low cost by avoiding `get()` calls.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership and ensures the document exists for update/delete.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /**
     * @description Validates that the userProfileId in the data matches the path parameter.
     * Used during creation to ensure the document is correctly linked to the owner.
     */
    function matchesPath(userProfileId) {
      return request.resource.data.userProfileId == userProfileId;
    }

    /**
     * @description Ensures that the userProfileId field cannot be changed after creation.
     */
    function remainsImmutable() {
      return request.resource.data.userProfileId == resource.data.userProfileId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for UserProfile. Users can only manage their own profile.
     * @path /userProfiles/{userProfileId}
     * @allow (create) if auth.uid == "user123" and path is /userProfiles/user123
     * @deny (list) if auth.uid == "user123" and attempting to list all profiles.
     * @principle Enforces self-creation and exclusive access to the user's own profile document.
     */
    match /userProfiles/{userProfileId} {
      allow get: if isOwner(userProfileId);
      allow list: if false; // Users should not be able to list other profiles
      
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userProfileId);

      /**
       * @description Rules for Property subcollection.
       * @path /userProfiles/{userProfileId}/properties/{propertyId}
       * @allow (list) if auth.uid matches the userProfileId in the path.
       * @deny (create) if the userProfileId in the document body doesn't match the path.
       * @principle Restricts property management to the owner identified in the path.
       */
      match /properties/{propertyId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }

      /**
       * @description Rules for Tenant subcollection.
       * @path /userProfiles/{userProfileId}/tenants/{tenantId}
       * @allow (get) if auth.uid matches the userProfileId in the path.
       * @deny (update) if the authenticated user attempts to change the userProfileId field.
       * @principle Ensures tenant data is only accessible to the managing landlord/user.
       */
      match /tenants/{tenantId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }

      /**
       * @description Rules for Tenancy agreements.
       * @path /userProfiles/{userProfileId}/tenancies/{tenancyId}
       * @allow (create) if auth.uid matches the userProfileId and provides correct ownership links.
       * @deny (delete) if the document does not exist or user is not the owner.
       * @principle Secures rental agreements within the landlord's private data tree.
       */
      match /tenancies/{tenancyId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }

      /**
       * @description Rules for MaintenanceRequest subcollection.
       * @path /userProfiles/{userProfileId}/maintenanceRequests/{maintenanceRequestId}
       * @allow (update) if the owner updates notes while maintaining the original owner ID.
       * @principle Protects maintenance history and tracking from unauthorized access.
       */
      match /maintenanceRequests/{maintenanceRequestId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }

      /**
       * @description Rules for property Inspections.
       * @path /userProfiles/{userProfileId}/inspections/{inspectionId}
       * @allow (list) if the user is viewing their own scheduled inspections.
       * @principle Validates relational integrity between the inspection record and the user.
       */
      match /inspections/{inspectionId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }

      /**
       * @description Rules for uploaded Documents.
       * @path /userProfiles/{userProfileId}/documents/{documentId}
       * @allow (create) if the user is uploading a document to their own document storage.
       * @principle Restricts document metadata access to the uploader.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }
    }

    /**
     * @description Catch-all rule for the root tenants collection.
     * The IR specifies tenants are subcollections of userProfiles.
     * Direct access to the root collection is denied to fix the reported error.
     */
    match /tenants/{tenantId} {
      allow read, write: if false; 
      // NOTE: The application should query /userProfiles/{uid}/tenants instead.
    }
  }
}