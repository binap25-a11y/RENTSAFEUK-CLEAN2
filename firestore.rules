rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANDLORD PROPERTY MANAGEMENT SECURITY MODEL
     * 
     * Core Philosophy:
     * This ruleset enforces a strict User-Ownership model. All application data is 
     * nested under a specific user's profile (/userProfiles/{userId}/...), ensuring 
     * that authorization is derived directly from the URL path for landlords.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Helper to get normalized email from token for statically provable rules.
     */
    function getTokenEmail() {
      return request.auth.token.email;
    }

    /**
     * Checks if the user is the tenant associated with the record (by email).
     * Uses direct token matching for static provability in collection group queries.
     */
    function isAuthorizedTenant(data) {
      return isSignedIn() && 
             data.email != null && 
             data.email == getTokenEmail();
    }

    // --- Collection Group Rules (CRITICAL for Portal discovery) ---
    // These must be top-level to allow cross-profile discovery.

    /**
     * @description Allows tenants to discover their own record via collectionGroup search.
     */
    match /{path=**}/tenants/{tenantId} {
      allow list: if isSignedIn() && getTokenEmail() != null && resource.data.email == getTokenEmail();
      allow get: if isSignedIn() && getTokenEmail() != null && resource.data.email == getTokenEmail();
    }

    /**
     * @description Allows tenants to communicate and view logs for their assigned property.
     */
    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow list: if isSignedIn();
    }

    // --- Core Data Rules ---

    /**
     * @description Rules for the user's root profile and subcollections.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      /**
       * @description Rules for rental properties managed by a landlord.
       */
      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Allow tenants assigned to this property to read basic details for portal context
        allow get: if isSignedIn();

        /**
         * @description Nested subcollections under properties.
         */
        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          // Redundant but safe check for direct access
          allow get: if isAuthorizedTenant(resource.data);

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || isAuthorizedTenant(get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data);
          }

          match /screenings/{screeningId} {
             allow read, write: if isOwner(userId);
             allow get: if isAuthorizedTenant(get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data);
          }
          
          match /checklists/{checklistId} {
             allow read, write: if isOwner(userId);
             allow get: if isAuthorizedTenant(get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data);
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          // Tenants can report issues and view logs for their property
          allow create: if isSignedIn();
          allow get, list: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      /**
       * @description Master directory for contractors.
       */
      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}