rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check ownership on a document by ownerId field
    function isOwner(doc) {
      return isSignedIn() && doc.ownerId == request.auth.uid;
    }

    // A user can manage their own profile document
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // A user can manage properties they own
    match /properties/{propertyId} {
      allow get: if isOwner(resource.data);
      // List queries are secured by client-side filtering and the `get` rule check on each document
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // A user can manage tenants they own
    match /tenants/{tenantId} {
      allow get: if isOwner(resource.data);
       // List queries are secured by client-side filtering and the `get` rule check on each document
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }
    
    // Generic rule for all property subcollections.
    // This handles both direct subcollection queries and collection group queries.
    match /properties/{propertyId}/{subcollection}/{docId}
    where subcollection in ['maintenanceLogs', 'inspections', 'documents', 'expenses', 'rentPayments'] {
      
      // Rule for reading individual documents (get) and for checking each document
      // returned by a list query.
      allow get: if isOwner(resource.data);
      
      // Rule for allowing list/query operations to proceed.
      // This is safe because the `get` rule above is checked for every document
      // and client-side queries MUST filter by ownerId.
      allow list: if isSignedIn();
      
      // Rules for writing data
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }
  }
}
