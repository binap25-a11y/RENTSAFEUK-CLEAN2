rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL TENANT DISCOVERY (TOP LEVEL) ---
    // Rules optimized for collectionGroup queries used in the Resident Hub.
    match /{path=**}/tenants/{tenantId} {
      // Allow discovery by email key (normalized)
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      
      // Allow access by secure linked UID
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow the identity handshake update.
      // Explicitly authorizes linking fields for verification.
      allow update: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      ) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'lastSyncCheck']);
    }

    // --- CORE PORTFOLIO HIERARCHY ---
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Tenants can read their assigned property record for context.
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          // Identity access for residents at specific paths.
          allow get: if isSignedIn() && (
            resource.data.email == request.auth.token.email.lower() || 
            resource.data.userId == request.auth.uid
          );

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.userId);
          }

          match /screenings/{screeningId} {
            allow read, write: if isOwner(userId);
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow read: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{allPaths=**} {
          allow read, write: if isOwner(userId);
        }

        match /checklists/{allPaths=**} {
          allow read, write: if isOwner(userId);
        }
        
        match /screenings/{allPaths=**} {
          allow read, write: if isOwner(userId);
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
