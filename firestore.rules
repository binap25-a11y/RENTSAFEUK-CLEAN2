rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFE UK - SECURITY GOVERNANCE
     * Matches the flat root-collection architecture used in the application code.
     */

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getAuthEmail() {
      return request.auth.token.email.lower();
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- PROPERTIES (Asset Registry) ---
    match /properties/{propertyId} {
      // Authorized query proving for landlords
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      
      // Authorized query proving for residents via email bridge
      allow list: if isSignedIn() && request.query.filters.tenantEmail == getAuthEmail();
      
      // Fallback for discovery
      allow list: if isSignedIn();

      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail()) ||
        (resource.data.activeTenantUids != null && request.auth.uid in resource.data.activeTenantUids)
      );
      
      allow create: if isSignedIn();
      
      /**
       * HANDSHAKE BRIDGE:
       * Allows a verified resident to link their UID to their assigned property.
       */
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- TENANTS (Identity Registry) ---
    match /tenants/{tenantId} {
      // Proof-optimized list branches
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.email == getAuthEmail();
      allow list: if isSignedIn() && request.query.filters.userId == request.auth.uid;

      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.email.lower() == getAuthEmail() ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.email.lower() == getAuthEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- MESSAGES (Secure Chat) ---
    match /messages/{messageId} {
      // Proof-optimized list branches
      allow list: if isSignedIn() && request.query.filters.tenantId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;

      allow get: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- REPAIRS / MAINTENANCE ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.query.filters.tenantId == request.auth.uid ||
        request.query.filters.tenantEmail == getAuthEmail()
      );
      
      // Discovery fallback
      allow list: if isSignedIn(); 

      allow get, update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail())
      );
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- DOCUMENTS & AUDIT ---
    match /documents/{docId} {
      allow list: if isSignedIn() && (
        request.query.filters.landlordId == request.auth.uid ||
        request.query.filters.propertyId != null
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.propertyId != null
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
    }

    // --- FINANCIALS & CONTRACTORS ---
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /contractors/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }

    // --- GLOBAL DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}