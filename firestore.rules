rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Maintain UK Security Governance v3.0
     * Optimized for high-speed Query-Compatible Discovery and Secure Handshake.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user is the landlord of the record
    function isLandlord(data) {
      return isSignedIn() && request.auth.uid == data.get('landlordId', '');
    }

    // Helper to check if the user is the tenant of the record (via UID or verified Email)
    function isTenant(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      return isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') ||
          (data.get('tenantEmails', []) is list && email in data.get('tenantEmails', []))
        ))
      );
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Discovery: Allow residents to find their registry entry by email
      // Management: Allow landlords to list their own tenants
      allow list: if isSignedIn() && (
        request.auth.token.email == resource.data.email ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.landlordId
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID if they match the registry email
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (request.auth.token.email == resource.data.email && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Discovery: Allow residents to find their property by email
      // Management: Allow landlords to list their portfolio
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.token.email == resource.data.tenantEmail
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID to the property bridge
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (request.auth.token.email == resource.data.tenantEmail && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Optimized for indexed chat queries
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid);
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      allow update: if isLandlord(resource.data) || isTenant(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow read: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isLandlord(resource.data);
      allow read: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }

    match /expenses/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }
    
    match /screenings/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }

    match /checklists/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }
  }
}