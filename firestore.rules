rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL SECURITY HELPERS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES (MUST BE AT TOP LEVEL FOR QUERIES) ---
    // These rules allow global discovery of identity across different landlord profiles.
    
    match /{path=**}/tenants/{tenantId} {
      /**
       * @description Authorized global identity handshake.
       * Uses direct token matching for static provability in collection group queries.
       * Note: 'email' in DB must be stored lowercase for this match to work reliably.
       */
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      allow get: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        resource.data.email == request.auth.token.email.lower()
      );
    }

    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow list, get: if isSignedIn();
       allow create: if isSignedIn();
    }

    // --- CORE HIERARCHICAL DATA ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Tenants can read their assigned property details for portal context.
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          // Standard check for resident access
          allow get: if isSignedIn() && resource.data.email == request.auth.token.email.lower();

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower());
          }

          match /screenings/{screeningId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower();
          }
          
          match /checklists/{checklistId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower();
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow get, list: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}