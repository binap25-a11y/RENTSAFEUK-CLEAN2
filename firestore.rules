rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      // Users can only read and write their own profile document.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections (Properties, Tenants, Contractors) ---
    match /properties/{propertyId} {
      // For 'list' queries, the client-side query MUST filter by ownerId.
      // For 'get', 'update', 'delete', this rule checks the ownerId on the existing document.
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      // For 'create', this rule ensures the new document has the correct owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // For 'list' queries, the client-side query MUST filter by ownerId.
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // --- Subcollections (e.g., maintenanceLogs, inspections, documents) ---
    match /properties/{propertyId}/{subcollection}/{docId} {
      // Allow read/write to subcollection if user owns the parent property document.
      // This is more efficient than checking a field in every subcollection document.
      allow read, update, delete: if isSignedIn() && get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      // For create, check the ownerId on the new document being created.
      // The app code must ensure ownerId is copied to all subcollection documents.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId}/{subcollection}/{docId} {
      // This follows the same pattern as property subcollections.
      allow read, update, delete: if isSignedIn() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
