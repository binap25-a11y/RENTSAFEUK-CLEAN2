rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Returns the user's email in lowercase for rule comparison
    // Uses .get() to handle cases where email might be missing from the token safely
    function authEmail() {
      return request.auth.token.get('email', "").lower();
    }

    // Global User Registry
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Property Registry (Portfolio Assets)
    match /properties/{id} {
      allow create: if isSignedIn();
      // Allow read if landlord OR assigned tenant (via UID or verified Email array)
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.get('tenantEmails', [])).hasAny([authEmail()])
      );
      // Handshake Authorization: Allow verified tenants to link their UID once
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (
          (resource.data.get('tenantEmails', [])).hasAny([authEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId']) &&
          request.resource.data.tenantId == request.auth.uid
        )
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Registry (Lease Mappings)
    match /tenants/{id} {
      allow create: if isSignedIn();
      // Optimized for high-speed discovery queries by email or UID
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.email == authEmail()
      );
      // Handshake Authorization: Allow self-link of UID to registry record
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (
          resource.data.email == authEmail() && 
          request.resource.data.userId == request.auth.uid
        )
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Shared Ledger Collections (Authorized by Context) ---
    
    // Professional Audit Trail Helper: Verifies residency via Property Document
    function isTenantOfProperty(propertyId) {
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      return isSignedIn() && (
        property.tenantId == request.auth.uid ||
        (property.get('tenantEmails', [])).hasAny([authEmail()])
      );
    }

    match /repairs/{id} {
      allow read, write: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
    }

    match /documents/{id} {
      allow read, write: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
    }

    match /messages/{id} {
      allow read, write: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
    }

    // --- Private Landlord Collections ---
    match /expenses/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /contractors/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /checklists/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /screenings/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    
    // Inspections (Shared Read for tenants)
    match /inspections/{id} {
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
    }
    
    // Rent Ledger (Shared Read for tenants)
    match /rentPayments/{id} {
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
    }
  }
}