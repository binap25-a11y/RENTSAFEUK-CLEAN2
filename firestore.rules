rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    //-------------------------------------------------------------------------
    // User Rules
    //-------------------------------------------------------------------------

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if false; // Explicitly deny listing all users
      allow create: if isOwner(userId);
    }

    //-------------------------------------------------------------------------
    // Property & Non-Grouped Sub-collection Rules
    //-------------------------------------------------------------------------

    match /properties/{propertyId} {
      allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid;

      // These sub-collections do not require collection group queries.
      match /maintenanceLogs/{maintenanceLogId} {
        allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }
      
      match /expenses/{expenseId} {
        allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }
    }

    //-------------------------------------------------------------------------
    // Tenant Rules
    //-------------------------------------------------------------------------

    match /tenants/{tenantId} {
      allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid;
    }

    //-------------------------------------------------------------------------
    // Collection Group Rules for Reminders Page & Direct Access
    //-------------------------------------------------------------------------

    match /{path=**}/documents/{documentId} {
      // This single rule block securely handles all access to 'documents' collections.
      allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid;
    }
    
    match /{path=**}/inspections/{inspectionId} {
      // This single rule block securely handles all access to 'inspections' collections.
      allow read, update, delete: if isSignedIn() && 'ownerId' in resource.data && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && 'ownerId' in request.resource.data && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
