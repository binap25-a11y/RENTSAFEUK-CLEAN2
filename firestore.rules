rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user matches the userId provided in the path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Combines ownership check with document existence for updates and deletes
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Landlords manage their own profile and all nested estate data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * Contractors Directory
       */
      match /contractors/{contractorId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      /**
       * Property Portfolio Root
       */
      match /properties/{propertyId} {
        allow get, list, create, update, delete: if isOwner(userId);

        /**
         * Resident Management
         */
        match /tenants/{tenantId} {
          allow get, list, create, update, delete: if isOwner(userId);
          
          match /screenings/{screeningId} {
            allow get, list, create, update, delete: if isOwner(userId);
          }
          
          match /messages/{messageId} {
            allow get, list, create: if isOwner(userId) || (isSignedIn() && request.auth.token.email.lower() == get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower());
          }
        }

        /**
         * Maintenance & Field Reports
         */
        match /maintenanceLogs/{logId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }

        match /inspections/{inspectionId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }

        /**
         * Compliance & Financials
         */
        match /documents/{docId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }

        match /expenses/{expenseId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
        
        match /checklists/{checklistId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Used for cross-property reporting and tenant portal discovery.

    match /{path=**}/tenants/{tenantId} {
      // Allow landlords to list all their tenants OR tenants to find their own record by email
      allow list: if isSignedIn() && (
        (resource != null && request.auth.uid == resource.data.ownerId) ||
        (resource != null && request.auth.token.email.lower() == resource.data.email.lower())
      );
      allow get: if isSignedIn() && (
        (resource != null && request.auth.uid == resource.data.ownerId) ||
        (resource != null && request.auth.token.email.lower() == resource.data.email.lower())
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && (
        (resource != null && request.auth.uid == resource.data.ownerId) ||
        (resource != null && (resource.data.reportedBy == request.auth.token.name || resource.data.reportedBy == request.auth.token.email))
      );
      allow create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow list: if isSignedIn() && (
        (resource != null && request.auth.uid == resource.data.ownerId) ||
        true // Restricted by application logic/queries
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get, create: if isSignedIn();
    }
  }
}