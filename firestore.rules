rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User can only access their own user document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- Properties ---
    match /properties/{propertyId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- Explicit Property Subcollections ---
    match /properties/{propertyId}/maintenanceLogs/{maintenanceLogId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
    }
    match /properties/{propertyId}/inspections/{inspectionId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
    }
    match /properties/{propertyId}/documents/{documentId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
    }
    match /properties/{propertyId}/expenses/{expenseId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
    }
    match /properties/{propertyId}/rentPayments/{rentPaymentId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- Tenants and subcollections ---
    match /tenants/{tenantId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;

      match /screenings/{screeningId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
      }
    }
    
    // --- Contractors ---
    match /contractors/{contractorId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }
  }
}
