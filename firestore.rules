
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the current user is the landlord of the record via relational key
    function isLandlordOf(data) {
      return isSignedIn() && (data.landlordId == request.auth.uid || data.userId == request.auth.uid);
    }

    // Check if the current user is the tenant linked to the record
    // We use case-insensitive email comparison to ensure reliability across identity providers
    function isTenantOf(data) {
      let userEmail = request.auth.token.email.lower();
      return isSignedIn() && (
        data.tenantId == request.auth.uid || 
        data.userId == request.auth.uid || 
        (data.email != null && data.email.lower() == userEmail) ||
        (data.tenantEmail != null && data.tenantEmail.lower() == userEmail)
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update, delete: if isLandlordOf(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }

    // --- 4. Repairs (Maintenance) ---
    match /repairs/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }

    // --- 5. Documents & Compliance ---
    match /documents/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update: if isLandlordOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }

    // --- 6. Secure Messaging ---
    match /messages/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data) || resource.data.senderId == request.auth.uid;
      allow update: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }

    // --- 7. Generic Ledger Access (Expenses, Inspections, Contractors, Screenings, checklists etc) ---
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isLandlordOf(resource.data) || isTenantOf(resource.data);
      allow update: if isLandlordOf(resource.data);
      allow delete: if isLandlordOf(resource.data);
    }
  }
}
