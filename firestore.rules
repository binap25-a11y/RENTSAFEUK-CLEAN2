
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- TENANT HANDSHAKE & DISCOVERY (TOP LEVEL) ---
    
    match /{path=**}/tenants/{tenantId} {
      // Allow tenants to discover their record by email.
      // This rule is strictly matched to the collectionGroup query.
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      
      // Allow tenants to access their record directly once UID is linked.
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Identity Verification: Allows the linking of identity keys.
      allow update: if isSignedIn() && 
        resource.data.email == request.auth.token.email.lower() &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'lastSyncCheck']);
    }

    // --- CORE PORTFOLIO HIERARCHY ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Verified residents can read their assigned property details
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          // Identity access for residents
          allow get: if isSignedIn() && (
            resource.data.email == request.auth.token.email.lower() || 
            resource.data.userId == request.auth.uid
          );

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.userId);
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow read: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
