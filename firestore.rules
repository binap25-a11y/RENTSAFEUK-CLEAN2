/**
 * Core Philosophy: This ruleset establishes a security model based on user ownership.
 * All primary data entities, such as properties and tenants, are intended to be
 * owned and managed by a specific authenticated user. Access to sub-collections
 * (like maintenance logs or documents) is derived from ownership of the parent
 * property.
 *
 * Data Structure: The data is organized into top-level collections for 'users',
 * 'properties', and 'tenants'. The 'properties' collection contains nested
 * sub-collections for 'maintenanceLogs', 'inspections', 'documents', and 'expenses',
 * creating a clear hierarchical relationship.
 *
 * Key Security Decisions:
 * - User data in `/users/{userId}` is strictly private to the owner. User listing
 *   is disabled to protect privacy.
 * - All primary and sub-collection documents require an `ownerId` field. This field is
 *   critical for securely and efficiently determining which user is authorized to
 *   read, write, or delete documents.
 * - Writes to sub-collections (e.g., creating a maintenance log) must validate
 *   that the `propertyId` within the document data matches the ID in the path,
 *   enforcing relational integrity.
 *
 * Denormalization for Authorization: The denormalized `ownerId` (the user's auth UID)
 * field on every document allows for simple, direct ownership checks and avoids
 * slow, costly, and non-scalable `get()` calls in rules. This is essential for
 * supporting collection group queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    //-------------------------------------------------------------------------
    // Collection Group Rules (for read operations)
    //-------------------------------------------------------------------------
    /**
     * @description Allows reading from any subcollection via a collection group query
     * if the user is the owner. This is essential for features like the Reminders
     * page that query across all properties.
     * The query MUST include `where('ownerId', '==', request.auth.uid)`.
     */
    match /{path=**}/documents/{documentId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/inspections/{inspectionId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/maintenanceLogs/{maintenanceLogId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/expenses/{expenseId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    //-------------------------------------------------------------------------
    // User Rules
    //-------------------------------------------------------------------------

    /**
     * @description Manages user profile data. A user can create their own
     * profile, and can only read or write their own data.
     * @path /users/{userId}
     * @allow (create) a new user document if `userId` matches `auth.uid`.
     * @deny (list) other user's profile documents.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
    }

    //-------------------------------------------------------------------------
    // Property Rules
    //-------------------------------------------------------------------------

    /**
     * @description Manages rental property information.
     * @path /properties/{propertyId}
     * @allow (create) a property if the user is signed in and sets themselves as the owner.
     * @allow (read, update, delete) a property if the user is the owner.
     * @principle Enforces owner-based access control.
     */
    match /properties/{propertyId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      //-------------------------------------------------------------------------
      // Maintenance Log Sub-collection Rules
      //-------------------------------------------------------------------------

      /**
       * @description Manages maintenance logs for a specific property.
       * @path /properties/{propertyId}/maintenanceLogs/{maintenanceLogId}
       * @allow (write) if the user owns the log and propertyId is consistent.
       * @principle Enforces owner-based access and relational integrity. Read is handled by collection group rule.
       */
      match /maintenanceLogs/{maintenanceLogId} {
        allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }

      //-------------------------------------------------------------------------
      // Inspection Sub-collection Rules
      //-------------------------------------------------------------------------

      /**
       * @description Manages inspection records for a specific property.
       * @path /properties/{propertyId}/inspections/{inspectionId}
       * @allow (write) if user owns the inspection and propertyId is consistent.
       * @principle Enforces owner-based access and relational integrity. Read is handled by collection group rule.
       */
      match /inspections/{inspectionId} {
        allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }

      //-------------------------------------------------------------------------
      // Document Sub-collection Rules
      //-------------------------------------------------------------------------

      /**
       * @description Manages documents (e.g., contracts) for a specific property.
       * @path /properties/{propertyId}/documents/{documentId}
       * @allow (write) if user owns the document and propertyId is consistent.
       * @principle Enforces owner-based access and relational integrity. Read is handled by collection group rule.
       */
      match /documents/{documentId} {
        allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }
      
      //-------------------------------------------------------------------------
      // Expense Sub-collection Rules
      //-------------------------------------------------------------------------
      /**
       * @description Manages expenses for a specific property.
       * @path /properties/{propertyId}/expenses/{expenseId}
       * @allow (write) if user owns the expense and propertyId is consistent.
       * @principle Enforces owner-based access and relational integrity. Read is handled by collection group rule.
       */
      match /expenses/{expenseId} {
        allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.propertyId == propertyId;
      }
    }

    //-------------------------------------------------------------------------
    // Tenant Rules
    //-------------------------------------------------------------------------

    /**
     * @description Manages tenant information.
     * @path /tenants/{tenantId}
     * @allow (create) a tenant if the user is signed in and sets themselves as the owner.
     * @allow (read, update, delete) a tenant if the user is the owner.
     * @principle Enforces owner-based access control.
     */
    match /tenants/{tenantId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
