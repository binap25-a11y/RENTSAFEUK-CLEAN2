
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTenantOfProperty(userId, propertyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(request.auth.uid));
    }

    match /userProfiles/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /properties/{propertyId} {
        allow get: if isOwner(userId) || isTenantOfProperty(userId, propertyId);
        allow read, write: if isOwner(userId);
        
        match /tenants/{id} { 
          allow read: if isOwner(userId) || (isSignedIn() && request.auth.uid == id);
          allow write: if isOwner(userId);

          match /messages/{mId} {
            allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.uid == id);
          }
        }
        
        match /maintenanceLogs/{id} { 
          allow read: if isOwner(userId) || isTenantOfProperty(userId, propertyId);
          allow create: if isOwner(userId) || isTenantOfProperty(userId, propertyId);
          allow update: if isOwner(userId);
        }

        match /documents/{id} {
          allow read: if isOwner(userId) || isTenantOfProperty(userId, propertyId);
          allow create: if isOwner(userId) || isTenantOfProperty(userId, propertyId);
        }
      }
    }

    match /{path=**}/tenants/{id} {
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid == id || resource.data.tenantUid == request.auth.uid);
    }
  }
}
