
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL DISCOVERY (REQUIRED FOR HANDSHAKE) ---
    
    match /{path=**}/tenants/{tenantId} {
      // Allow tenants to discover their own record by email or linked UID.
      // Rules must be simple for collectionGroup query safety.
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
      
      // Verification Handshake: Allow the tenant to link their UID once.
      // Restrict updates to only identity-mapping fields.
      allow update: if isSignedIn() && 
        resource.data.email == request.auth.token.email.lower() &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'lastSyncCheck']);
    }

    // --- CORE HIERARCHICAL PORTFOLIO DATA ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Residents can read basic property details for the home they are assigned to
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          allow get: if isSignedIn() && (
            resource.data.email == request.auth.token.email.lower() || 
            resource.data.userId == request.auth.uid
          );

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.userId);
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow read: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
