rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
      
      match /screenings/{screeningId} {
        allow read, write: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
      }
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);

      // Sub-collections: maintenanceLogs, inspections, documents, expenses, rentPayments, checklists
      match /{subcollection}/{docId=**} {
        allow read, write: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
      }
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }

    // --- Collection Group Rules (Broad Read for Aggregation) ---
    match /{path=**}/maintenanceLogs/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/rentPayments/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/expenses/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/checklists/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}