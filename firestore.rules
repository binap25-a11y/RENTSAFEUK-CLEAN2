rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User can only access their own user document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- Properties and all subcollections ---
    match /properties/{propertyId} {
      allow get: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid;

      match /{subcollection}/{docId} {
        // This rule is simpler and more robust.
        // It relies on the subcollection documents also having an `ownerId`.
        // The client-side queries MUST filter by this ownerId for list operations.
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Tenants and subcollections ---
    match /tenants/{tenantId} {
      allow get: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid;

      match /screenings/{screeningId} {
        allow get, update, delete: if resource.data.ownerId == request.auth.uid;
        allow list: if request.auth.uid != null; // Client MUST filter by ownerId
        allow create: if request.resource.data.ownerId == request.auth.uid;
      }
    }
    
    // --- Contractors ---
    match /contractors/{contractorId} {
      allow get: if resource.data.ownerId == request.auth.uid;
      allow list: if request.auth.uid != null; // Client MUST filter by ownerId
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid;
    }
  }
}
