rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is the landlord of a document
    function isLandlord(data) {
      return isSignedIn() && data.landlordId == request.auth.uid;
    }

    // Helper to check if user is a tenant of a specific property
    // Optimized for GET calls only
    function isTenantOfProperty(propertyId) {
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      let email = request.auth.token.email == null ? "" : request.auth.token.email.lower();
      return isSignedIn() && (
        property.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in property && email in property.tenantEmails)
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in resource.data && request.auth.token.email.lower() in resource.data.tenantEmails)
      );
      // Allow tenants to update their tenantId link during discovery handshake
      allow update: if isLandlord(resource.data) || (
        isSignedIn() && 
        request.auth.token.email != null && 
        "tenantEmails" in resource.data && 
        request.auth.token.email.lower() in resource.data.tenantEmails && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId']) &&
        request.resource.data.tenantId == request.auth.uid
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      // Authorized identity discovery: Landlord OR Self (via UID) OR Self (via Email matching)
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == request.auth.token.email.lower())
      );
      // Allow self-verification handshake
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == request.auth.token.email.lower())
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 4. Ledger Collections (Repairs, Documents, Messages, Expenses, etc) ---
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "email" in resource.data && resource.data.email == request.auth.token.email.lower()) ||
        (request.auth.token.email != null && "tenantEmail" in resource.data && resource.data.tenantEmail == request.auth.token.email.lower()) ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow delete: if isLandlord(resource.data);
    }
  }
}