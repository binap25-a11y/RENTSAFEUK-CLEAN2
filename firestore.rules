rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Optimized email retrieval for query analysis.
    // Using direct token access aligns with Firestore's static query optimizer.
    function authEmail() {
      return isSignedIn() ? request.auth.token.get('email', '') : '';
    }

    // Helper: Validates if the authenticated user is the registered resident.
    // Performs direct string comparisons to ensure 100% query compatibility.
    function isRegisteredResident(data) {
      let email = authEmail();
      return email != '' && (
        data.get('tenantEmail', '') == email ||
        data.get('email', '') == email ||
        email in data.get('tenantEmails', [])
      );
    }

    // Global User Registry
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Property Registry (Portfolio Assets)
    match /properties/{id} {
      allow create: if isSignedIn();
      
      // Authorized Read: Query-compatible matches.
      // Tenants can read properties where their UID is linked OR their email is registered.
      allow get, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        isRegisteredResident(resource.data)
      );
      
      // Handshake Authorization: Allow residents to link their UID once.
      // This rule is critical for the transition from email-based discovery to permanent UID access.
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (
          isRegisteredResident(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId']) &&
          request.resource.data.tenantId == request.auth.uid
        )
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Registry (Identity Mappings)
    match /tenants/{id} {
      allow create: if isSignedIn();
      
      // Authorized Read: Direct UID or Email matches.
      allow get, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        (authEmail() != '' && resource.data.email == authEmail())
      );
      
      // Handshake Authorization: Link verified UID to record.
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (
          authEmail() != '' && 
          resource.data.email == authEmail() && 
          request.resource.data.userId == request.auth.uid
        )
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Shared Ledger Collections (Optimized for Tenant Access)
    
    function isAuthorizedForProperty(propertyId) {
      if (propertyId == null) { return false; }
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      return isSignedIn() && (
        property.landlordId == request.auth.uid ||
        property.tenantId == request.auth.uid ||
        isRegisteredResident(property)
      );
    }

    match /repairs/{id} {
      allow create: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        (authEmail() != '' && resource.data.get('tenantEmail', '') == authEmail())
      );
      allow get, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        isAuthorizedForProperty(resource.data.propertyId)
      );
    }

    match /documents/{id} {
      allow create: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        isAuthorizedForProperty(resource.data.propertyId)
      );
      allow get, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        isAuthorizedForProperty(resource.data.propertyId)
      );
    }

    match /messages/{id} {
      allow create: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow get, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid || 
        isAuthorizedForProperty(resource.data.propertyId)
      );
    }

    // Private Landlord Collections
    match /expenses/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /contractors/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /checklists/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    match /screenings/{id} { allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid; }
    
    match /inspections/{id} {
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        isAuthorizedForProperty(resource.data.propertyId)
      );
    }
    
    match /rentPayments/{id} {
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid || 
        isAuthorizedForProperty(resource.data.propertyId)
      );
    }
  }
}