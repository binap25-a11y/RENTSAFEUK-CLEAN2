
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidOwnership(userId) {
      return request.resource.data.userId == userId;
    }

    function isOwnershipImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    // Required for Role Detection & Portal Authentication
    match /{path=**}/tenants/{tenantId} {
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    // Secure Messenger discovery
    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        // Check assigned resident email for portal access
        get(/databases/$(database)/documents/userProfiles/$(resource.data.userId)/properties/$(resource.data.propertyId)/tenants/$(resource.data.tenantId)).data.email == request.auth.token.email
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * @description Recursive portfolio oversight for Landlords.
       * Grants the property owner full read/write access to all nested data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }

      match /properties/{propertyId} {
        // Limited GET for Tenants to view their own home details
        allow get: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)) && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)).data.email == request.auth.token.email;

        match /tenants/{tenantId} {
          // Resident can read their own contract
          allow get: if isSignedIn() && resource.data.email == request.auth.token.email;
          
          match /messages/{messageId} {
            allow read, write: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email;
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)) && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)).data.email == request.auth.token.email;
        }

        match /documents/{docId} {
          allow read: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)) && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId)).data.email == request.auth.token.email;
        }
      }
    }
  }
}
