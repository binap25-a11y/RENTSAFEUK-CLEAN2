rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    /**
     * Discovery rules for Tenants.
     * Required for the dashboard role-check logic.
     */
    match /{path=**}/tenants/{tenantId} {
      // Allows residents to find their own records via character-perfect email match
      // Allows landlords to list their own tenants via character-perfect userId match
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    /**
     * Secure direct communication channel.
     */
    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
    }

    /**
     * Repair audit trail discovery.
     */
    match /{path=**}/maintenanceLogs/{logId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * Recursive portfolio oversight for Landlords.
       * Grants the property owner full access to all nested asset data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}