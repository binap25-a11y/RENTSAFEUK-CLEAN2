rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance
     * Optimized for high-speed identity discovery and verified Resident Hub access.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Direct token access is preferred for query optimization
    function authEmail() {
      return (request.auth.token.email != null) ? request.auth.token.email.lower() : '';
    }

    // Landlord check: verifies if user owns the record or the parent property context
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '') || 
        request.auth.uid == data.get('userId', '')
      );
    }

    // Tenant check: establishes authorization via UID handshake or verified email registry
    function isTenant(data) {
      let email = authEmail();
      return isSignedIn() && (
        request.auth.uid == data.get('tenantId', '') || 
        request.auth.uid == data.get('userId', '') ||
        request.auth.uid in data.get('activeTenantUids', []) ||
        (email != '' && email == data.get('email', '').lower()) ||
        (email != '' && email == data.get('tenantEmail', '').lower()) ||
        (email != '' && email in data.get('tenantEmails', []))
      );
    }

    // General authorization check for relational records
    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // allow list MUST be statically verifiable for high-speed discovery queries
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      // HANDSHAKE: Allow verified residents to link their UID to the property record
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'tenantEmail', 'tenantEmails']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Portals & Audit Trails ---
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /checklists/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow get: if isLandlord(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isLandlord(resource.data);
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow get: if isLandlord(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    // --- Generic Catch-all ---
    match /{path=**} {
      allow read, write: if isSignedIn() && (
        (resource != null && isLandlord(resource.data)) ||
        (request.resource != null && isLandlord(request.resource.data))
      );
    }
  }
}