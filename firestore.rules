rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(docData) {
      return request.auth.uid == docData.ownerId;
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow get: if isOwner(resource.data);
      allow list: if request.auth.uid != null;
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    match /tenants/{tenantId} {
      allow get: if isOwner(resource.data);
      allow list: if request.auth.uid != null;
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    match /contractors/{contractorId} {
      allow get: if isOwner(resource.data);
      allow list: if request.auth.uid != null;
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    match /properties/{propertyId}/maintenanceLogs/{maintenanceLogId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data);
      allow create: if isOwner(request.resource.data);
    }
    
    match /properties/{propertyId}/inspections/{inspectionId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data);
      allow create: if isOwner(request.resource.data);
    }
    
    match /properties/{propertyId}/documents/{documentId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data);
      allow create: if isOwner(request.resource.data);
    }
    
    match /properties/{propertyId}/expenses/{expenseId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data);
      allow create: if isOwner(request.resource.data);
    }
    
    match /properties/{propertyId}/rentPayments/{rentPaymentId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data);
      allow create: if isOwner(request.resource.data);
    }
    
    match /tenants/{tenantId}/screenings/{screeningId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/tenants/$(tenantId)).data);
      allow create: if isOwner(request.resource.data);
    }
  }
}
