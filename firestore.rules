rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFE UK - SECURITY GOVERNANCE v2.5
     * Optimized for high-speed query verification and secure resident handshakes.
     */

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safely retrieves the normalized auth email
    function getAuthEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : "";
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- PROPERTIES (Asset Registry) ---
    match /properties/{propertyId} {
      // Discrete branches for static query verification
      // Combined for optimizer prove-ability
      allow list: if isSignedIn() && (
        request.query.filters.get('landlordId', '') == request.auth.uid ||
        request.query.filters.get('tenantEmail', '') == getAuthEmail()
      );

      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail()) ||
        (resource.data.activeTenantUids != null && request.auth.uid in resource.data.activeTenantUids)
      );
      
      allow create: if isSignedIn();
      
      /**
       * HANDSHAKE BRIDGE:
       * Allows a verified resident to link their UID to their assigned property record.
       */
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- TENANTS (Identity Registry) ---
    match /tenants/{tenantId} {
      // Unified query filter validation
      allow list: if isSignedIn() && (
        request.query.filters.get('landlordId', '') == request.auth.uid ||
        request.query.filters.get('email', '') == getAuthEmail() ||
        request.query.filters.get('userId', '') == request.auth.uid
      );

      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get('email', '').lower() == getAuthEmail() ||
        resource.data.userId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.get('email', '').lower() == getAuthEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- MESSAGES (Secure Chat) ---
    match /messages/{messageId} {
      // Proof-optimized query validation
      allow list: if isSignedIn() && (
        request.query.filters.get('tenantId', '') == request.auth.uid ||
        request.query.filters.get('landlordId', '') == request.auth.uid
      );

      allow get: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- REPAIRS / MAINTENANCE ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        request.query.filters.get('landlordId', '') == request.auth.uid ||
        request.query.filters.get('tenantId', '') == request.auth.uid ||
        request.query.filters.get('tenantEmail', '') == getAuthEmail()
      );
      
      allow get, update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.tenantEmail != null && resource.data.tenantEmail.lower() == getAuthEmail())
      );
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- DOCUMENTS & AUDIT ---
    match /documents/{docId} {
      allow list: if isSignedIn() && (
        request.query.filters.get('landlordId', '') == request.auth.uid ||
        request.query.filters.get('propertyId', '') != ''
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.propertyId != null
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
    }

    // --- FINANCIALS & CONTRACTORS ---
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /contractors/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow read, write: if isSignedIn() && (resource.data.landlordId == request.auth.uid || request.resource.data.landlordId == request.auth.uid);
    }

    // --- GLOBAL DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}