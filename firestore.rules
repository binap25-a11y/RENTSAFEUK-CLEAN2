rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get lowercased email for comparison
    function authEmail() {
      return request.auth.token.email == null ? "" : request.auth.token.email.lower();
    }

    // Helper to check if user is the landlord of a document
    function isLandlord(data) {
      return isSignedIn() && data.landlordId == request.auth.uid;
    }

    // Helper to check if user is an authorized tenant of a property
    function isTenantOfProperty(propertyId) {
      let property = get(/databases/$(database)/documents/properties/$(propertyId)).data;
      return isSignedIn() && (
        property.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in property && authEmail() in property.tenantEmails)
      );
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "tenantEmails" in resource.data && authEmail() in resource.data.tenantEmails)
      );
      // Allow tenants to update their tenantId link during handshake
      allow update: if isLandlord(resource.data) || (
        isSignedIn() && 
        request.auth.token.email != null && 
        "tenantEmails" in resource.data && 
        authEmail() in resource.data.tenantEmails && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId']) &&
        request.resource.data.tenantId == request.auth.uid
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      // Allow searching by email for first-time handshake
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == authEmail())
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (request.auth.token.email != null && resource.data.email == authEmail())
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- 4. Ledger Collections (Repairs, Documents, Messages, etc) ---
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (request.auth.token.email != null && "email" in resource.data && resource.data.email == authEmail()) ||
        (request.auth.token.email != null && "tenantEmail" in resource.data && resource.data.tenantEmail == authEmail()) ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        ("propertyId" in resource.data && isTenantOfProperty(resource.data.propertyId))
      );
      allow delete: if isLandlord(resource.data);
    }
  }
}