rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL TENANT DISCOVERY ---
    // Optimized for collectionGroup queries. 
    // Uses direct field matching to ensure static verification during indexing.
    match /{path=**}/tenants/{tenantId} {
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
      
      // Explicitly authorize identity linking fields. 
      // Prevents "Permission Denied" during the Portal Handshake.
      allow update: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      ) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'lastSyncCheck']);
    }

    // --- CORE PORTFOLIO HIERARCHY ---
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      // Recursive match grants landlords unambiguous access to all nested property data
      // Fixes permission errors in rentPayments, screenings, and checklists.
      match /properties/{propertyId}/{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
      
      // Legacy explicit matches for clarity and specific tenant overrides
      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        allow get: if isSignedIn(); // Allow residents to resolve property context

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.userId);
          }
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}