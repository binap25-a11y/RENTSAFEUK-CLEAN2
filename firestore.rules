
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v20.14
     * Synchronized with high-performance cross-collection lookups for Resident Hub accessibility.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : "";
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /residents/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail() ||
        userEmail() in resource.data.get('tenantEmails', [])
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail() ||
        userEmail() in resource.data.get('tenantEmails', [])
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.get("tenantEmail", "").lower() == userEmail() ||
        userEmail() in resource.data.get('tenantEmails', [])
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow get, list: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email.lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.email.lower() == userEmail() ||
        resource.data.userId == request.auth.uid
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get('tenantUid', '') == request.auth.uid ||
        resource.data.get('senderId', '') == request.auth.uid ||
        resource.data.get('tenantEmail', '').lower() == userEmail()
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid
      );

      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get('tenantUid', '') == request.auth.uid ||
        resource.data.get('tenantEmail', '').lower() == userEmail()
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.senderId == request.auth.uid);
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow get, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedBy == request.auth.uid ||
        resource.data.get('tenantEmail', '').lower() == userEmail() ||
        (resource.data.propertyId != null && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) && (
          request.auth.uid in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('activeTenantUids', []) ||
          userEmail() in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('tenantEmails', []) ||
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.landlordId == request.auth.uid
        ))
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Documents ---
    match /documents/{id} {
      allow get, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.get('sharedWithTenant', false) == true && 
         resource.data.propertyId != null && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) && (
           request.auth.uid in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('activeTenantUids', []) ||
           userEmail() in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('tenantEmails', []) ||
           get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.landlordId == request.auth.uid
         ))
      );
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Emergency Procedures ---
    match /emergencyInfo/{propertyId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        exists(/databases/$(database)/documents/properties/$(propertyId)) && (
          request.auth.uid in get(/databases/$(database)/documents/properties/$(propertyId)).data.get('activeTenantUids', []) ||
          get(/databases/$(database)/documents/properties/$(propertyId)).data.get('tenantEmail', "").lower() == userEmail() ||
          userEmail() in get(/databases/$(database)/documents/properties/$(propertyId)).data.get('tenantEmails', [])
        )
      );
      allow write: if isSignedIn() && (
        (resource == null && get(/databases/$(database)/documents/properties/$(propertyId)).data.landlordId == request.auth.uid) ||
        resource.data.landlordId == request.auth.uid
      );
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- General Audits ---
    match /contractors/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
    
    match /inspections/{id} { 
      allow get, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.propertyId != null && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) && (
          request.auth.uid in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('activeTenantUids', []) ||
          userEmail() in get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.get('tenantEmails', []) ||
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.landlordId == request.auth.uid
        ))
      );
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); 
    }

    match /screenings/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
    match /checklists/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
  }
}
