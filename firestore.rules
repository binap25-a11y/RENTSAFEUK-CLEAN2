
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK CORE SECURITY GOVERNANCE
     * Optimized for flat root collection architecture and static query verification.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      // Split list rules into discrete branches for static query proof
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.auth.uid in request.query.filters.activeTenantUids;
      allow list: if isSignedIn() && userEmail() == request.query.filters.tenantEmail;
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.activeTenantUids ||
        userEmail() == resource.data.tenantEmail
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Allows residents to link their UID on first login
        (userEmail() == resource.data.tenantEmail && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.userId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.email == userEmail();
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Allows residents to update their own identity link
        (resource.data.email == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance / Repairs ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.tenantId == request.auth.uid;
      
      allow get: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
    }

    // --- Resident Communication Hub ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && request.query.filters.tenantId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      
      allow read: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Financial Ledger ---
    match /expenses/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /rentPayments/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Compliance & Safety ---
    match /documents/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.propertyId != null;
      
      allow get: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.propertyId != null);
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /contractors/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow list: if isSignedIn() && request.query.filters.propertyId != null;
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /screenings/{id} {
      allow list: if isSignedIn() && request.query.filters.landlordId == request.auth.uid;
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
  }
}
