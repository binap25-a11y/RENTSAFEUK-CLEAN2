
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated user matches the userId provided in the path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full recursive access to their own profile and all nested portfolio data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Prevent listing of all profiles

      // Recursive rule for all nested portfolio data (properties, tenants, maintenance, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Essential for role discovery and cross-portfolio reporting.

    match /{path=**}/tenants/{tenantId} {
      // Allow tenants to find their own records via email query
      // Allow landlords to manage their own tenant records
      allow list, get: if isSignedIn() && (
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (resource != null && request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower())
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Allow tenants to view logs for properties they reside in
      // Verification is handled by application logic matching email to active tenant
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      // Tenants can view shared compliance documents
      allow list, get: if isSignedIn();
    }

    match /{path=**}/messages/{messageId} {
      // Secure messaging for active tenancies
      allow list, get, create: if isSignedIn();
    }
  }
}
