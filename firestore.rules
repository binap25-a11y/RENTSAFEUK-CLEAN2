rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check ownership on a document by the ownerId field.
    // This is the primary security mechanism for user data.
    function isOwner(doc) {
      return isSignedIn() && doc.ownerId == request.auth.uid;
    }

    // Profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Top-level collections
    match /properties/{propertyId} {
      allow list: if isSignedIn();
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    match /tenants/{tenantId} {
      allow list: if isSignedIn();
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }
    
    // --- DIRECT SUBCOLLECTION ACCESS RULES ---
    // These rules cover direct access like /properties/{pid}/inspections/{iid}
    // but DO NOT cover collection group queries.

    match /properties/{propertyId}/maintenanceLogs/{logId} {
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    match /properties/{propertyId}/inspections/{inspectionId} {
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    match /properties/{propertyId}/documents/{documentId} {
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    match /properties/{propertyId}/expenses/{expenseId} {
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    match /properties/{propertyId}/rentPayments/{paymentId} {
      allow get, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    // --- COLLECTION GROUP QUERY RULES ---
    // These rules are ONLY for collection group queries.
    // They allow `list` operations across all subcollections with the same name.
    // The client-side query MUST use `where('ownerId', '==', user.uid)`.

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isOwner(resource.data);
    }
    match /{path=**}/inspections/{inspectionId} {
      allow list: if isOwner(resource.data);
    }
    match /{path=**}/documents/{documentId} {
      allow list: if isOwner(resource.data);
    }
    match /{path=**}/expenses/{expenseId} {
      allow list: if isOwner(resource.data);
    }
    match /{path=**}/rentPayments/{paymentId} {
      allow list: if isOwner(resource.data);
    }
  }
}
