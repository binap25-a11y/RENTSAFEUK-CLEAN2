rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is the owner of a document.
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Helper function to check if the user owns the parent property.
    function isParentOwner(propertyId) {
      return get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // --- USER DATA ---
    // A user can manage their own document.
    match /users/{userId} {
      allow get, update, delete, create: if isOwner(userId);

      // TENANTS SUB-COLLECTION: Tenants are owned by a user.
      match /tenants/{tenantId} {
        // Allow full CRUD on specific tenant documents by the owner.
        allow get, update, delete: if isOwner(userId);
        
        // SCREENINGS SUB-SUB-COLLECTION
        match /screenings/{screeningId} {
          allow get, update, delete: if isOwner(userId);
        }
        match /screenings {
           allow create, list: if isOwner(userId);
        }
      }
      match /tenants {
        // Allow creating new tenants and listing existing ones for the owner.
        allow create, list: if isOwner(userId);
      }
    }
    
    // --- PROPERTIES ---
    // Rules for individual property documents.
    match /properties/{propertyId} {
      // Allow read, update, and delete only if ownerId matches the user's UID.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;

      // --- PROPERTY SUB-COLLECTIONS ---
      // These rules apply to all sub-collections of a property.
      // They ensure that only the owner of the parent property can access sub-collection data.
      
      // Maintenance Logs
      match /maintenanceLogs/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /maintenanceLogs { allow create, list: if isParentOwner(propertyId); }
      
      // Inspections
      match /inspections/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /inspections { allow create, list: if isParentOwner(propertyId); }

      // Documents
      match /documents/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /documents { allow create, list: if isParentOwner(propertyId); }
      
      // Expenses
      match /expenses/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /expenses { allow create, list: if isParentOwner(propertyId); }
      
      // Rent Payments
      match /rentPayments/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /rentPayments { allow create, list: if isParentOwner(propertyId); }
      
      // Checklists
      match /checklists/{docId} { allow get, update, delete: if isParentOwner(propertyId); }
      match /checklists { allow create, list: if isParentOwner(propertyId); }
    }
    // Rules for the properties collection as a whole.
    match /properties {
      // Allow creating a property if the new document's ownerId is the user's UID.
      allow create: if request.resource.data.ownerId == request.auth.uid;
      // Allow listing properties only when the query is filtered by the user's UID.
      allow list: if request.query.where.ownerId == request.auth.uid;
    }

    // --- CONTRACTORS ---
    // Rules for individual contractor documents.
    match /contractors/{contractorId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
    }
    // Rules for the contractors collection.
    match /contractors {
      allow create: if request.resource.data.ownerId == request.auth.uid;
      // Allow listing contractors only when the query is filtered by the user's UID.
      allow list: if request.query.where.ownerId == request.auth.uid;
    }
  }
}
