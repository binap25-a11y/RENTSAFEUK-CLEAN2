
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function matchesPath(userProfileId) {
      return request.resource.data.userId == userProfileId;
    }

    function remainsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow get: if isOwner(userProfileId);
      allow list: if false;
      
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userProfileId);

      match /properties/{propertyId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);

        match /maintenanceLogs/{logId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /inspections/{inspectionId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /documents/{documentId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /tenants/{tenantId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);

          match /screenings/{screeningId} {
            allow get, list: if isOwner(userProfileId);
            allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
            allow update: if isExistingOwner(userProfileId) && remainsImmutable();
            allow delete: if isExistingOwner(userProfileId);
          }

          match /messages/{messageId} {
            allow get, list: if isOwner(userProfileId);
            allow create: if isOwner(userProfileId);
            allow update, delete: if isExistingOwner(userProfileId);
          }
        }

        match /rentPayments/{paymentId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }
        
        match /expenses/{expenseId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }

        match /checklists/{checklistId} {
          allow get, list: if isOwner(userProfileId);
          allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
          allow update: if isExistingOwner(userProfileId) && remainsImmutable();
          allow delete: if isExistingOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId) && matchesPath(userProfileId);
        allow update: if isExistingOwner(userProfileId) && remainsImmutable();
        allow delete: if isExistingOwner(userProfileId);
      }
    }

    // --- Unified collectionGroup Rules ---
    // Consolidated for static provability in collectionGroup list operations

    match /{path=**}/tenants/{tenantId} {
      allow list, get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }
  }
}
