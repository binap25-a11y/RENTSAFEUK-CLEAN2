
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL SECURITY HELPERS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- TOP-LEVEL DISCOVERY RULES (CRITICAL FOR IDENTITY HANDSHAKE) ---
    
    match /{path=**}/tenants/{tenantId} {
      // Identity Discovery: Rules must be strictly query-safe for collectionGroup.
      // We split the rules to ensure Firestore can optimize the index lookup.
      
      // 1. Allow discovery by exactly matching the authenticated email
      allow read: if isSignedIn() && (
        request.auth.token.email != null && 
        resource.data.email == request.auth.token.email.lower()
      );
      
      // 2. Allow discovery by the linked UID (once verified)
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Verification Handshake: Allow the resident to link their unique UID.
      allow update: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email == request.auth.token.email.lower()) ||
        (resource.data.userId == request.auth.uid || resource.data.userId == '')
      ) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['joinedDate', 'userId', 'verified', 'lastSyncCheck']);
    }

    // --- SHARED DATA ACCESS RULES ---

    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn();
    }

    // --- CORE HIERARCHICAL PORTFOLIO DATA ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Residents can read basic property details for the home they are assigned to
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          allow get: if isSignedIn() && (
            (request.auth.token.email != null && resource.data.email == request.auth.token.email.lower()) ||
            resource.data.userId == request.auth.uid
          );

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.token.email != null && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower());
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow read: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
