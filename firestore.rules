rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile Rules ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collection Rules ---
    match /properties/{propertyId} {
      // READ: Allow reading a property if the user is the owner.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      // WRITE: Allow creating, updating, deleting a property if the user is the owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    
    // --- Collection Group & Direct Sub-collection Access ---
    // The /{path=**}/... wildcard path applies to collection group queries and direct access.
    // This single set of rules is more robust and simpler to maintain.

    function isDocOwner() {
      // This function is used for read, update, and delete operations where 'resource' exists.
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    function isCreatingDocAsOwner() {
      // This function is used for 'create' operations where 'resource' does not exist yet.
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow read: if isDocOwner();
      allow write: if isCreatingDocAsOwner() || isDocOwner();
    }
    match /{path=**}/inspections/{inspectionId} {
      allow read: if isDocOwner();
      allow write: if isCreatingDocAsOwner() || isDocOwner();
    }
    match /{path=**}/documents/{documentId} {
      allow read: if isDocOwner();
      allow write: if isCreatingDocAsOwner() || isDocOwner();
    }
    match /{path=**}/expenses/{expenseId} {
      allow read: if isDocOwner();
      allow write: if isCreatingDocAsOwner() || isDocOwner();
    }
    match /{path=**}/rentPayments/{paymentId} {
      allow read: if isDocOwner();
      allow write: if isCreatingDocAsOwner() || isDocOwner();
    }
  }
}
