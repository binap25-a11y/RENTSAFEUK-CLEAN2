rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections ---
    match /properties/{propertyId} {
      // Any signed-in user can query properties, but the query must be filtered by ownerId on the client.
      allow list: if isSignedIn();
      // Only the owner can get, create, update, or delete their property.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // Any signed-in user can query tenants, but the query must be filtered by ownerId on the client.
      allow list: if isSignedIn();
      // Only the owner can get, create, update, or delete their tenant records.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Collection Group Rules for Subcollections ---
    // These rules apply to both collection group queries (like on the dashboard) and direct access.
    
    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if request.auth != null && request.query.limit <= 30;
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/inspections/{inspectionId} {
      allow list: if request.auth != null && request.query.limit <= 30;
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/documents/{documentId} {
      allow list: if request.auth != null && request.query.limit <= 30;
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/expenses/{expenseId} {
      allow list: if request.auth != null && request.query.limit <= 30;
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/rentPayments/{paymentId} {
      allow list: if request.auth != null && request.query.limit <= 30;
      allow get, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
