
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    // Required for Role Detection & Portal Authentication
    match /{path=**}/tenants/{tenantId} {
      // Residents discovery query requires proof-of-identity filter
      allow list: if isSignedIn() && (
        resource.data.email.lower() == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        resource.data.email.lower() == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
    }

    // Secure Messenger discovery
    match /{path=**}/messages/{messageId} {
      // Limit discovery to authorized participants
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.senderId == request.auth.uid
      );
    }

    // Maintenance discovery for residents
    match /{path=**}/maintenanceLogs/{logId} {
      // Landlords can list all logs; Residents can list logs for their specific property context
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.reportedBy == request.auth.token.name ||
        resource.data.reportedBy == request.auth.token.email
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * @description Recursive portfolio oversight for Landlords.
       * Grants the property owner full read/write access to all nested data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }

      match /properties/{propertyId} {
        // Limited GET for Tenants to view their own home details
        // Note: Landlords are covered by the recursive rule above.
        allow get: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId));

        match /tenants/{tenantId} {
          // Resident can read their own profile
          allow get: if isSignedIn() && resource.data.email.lower() == request.auth.token.email.lower();
          
          match /messages/{messageId} {
            allow read, write: if isSignedIn() && (
              get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == request.auth.token.email.lower()
            );
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId));
        }

        match /documents/{docId} {
          allow read: if isSignedIn() && exists(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(anyId));
        }
      }
    }
  }
}
