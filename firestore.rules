
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v17.0
     * Optimized for high-speed query compatibility and atomic resident handshakes.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.get('email', '').lower();
    }

    function getUid() {
      return request.auth.uid;
    }

    // Helper to check if the user is the landlord of the record
    function isLandlord(data) {
      return isSignedIn() && getUid() == data.get('landlordId', '');
    }

    // Helper to check if the user is the tenant of the record (Handshaked UID)
    function isTenant(data) {
      return isSignedIn() && (
        getUid() == data.get('tenantId', '') || 
        getUid() == data.get('userId', '') ||
        getUid() == data.get('reportedBy', '')
      );
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && getUid() == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // DISCOVERY: Proof-optimized for collection scans matching identity keys
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.userId ||
        getEmail() == resource.data.email
      );
      
      allow get: if isSignedIn() && (
        isLandlord(resource.data) || 
        isTenant(resource.data) || 
        getEmail() == resource.data.get('email', '').lower()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID if they match the registry email
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (getEmail() == resource.data.get('email', '').lower() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // DISCOVERY: Optimized for high-speed scans
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId ||
        resource.data.activeTenantUids.hasAny([getUid()]) ||
        getEmail() == resource.data.get('tenantEmail', '').lower()
      );

      allow get: if isSignedIn() && (
        isLandlord(resource.data) || 
        isTenant(resource.data) || 
        getEmail() == resource.data.get('tenantEmail', '').lower()
      );
      
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID to the property bridge if authorized by email
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (getEmail() == resource.data.get('tenantEmail', '').lower() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // PROOF-OPTIMIZED: Uses direct string matching for query Prove-ability
      allow list: if isSignedIn() && (
        getUid() == resource.data.tenantId || 
        getUid() == resource.data.landlordId
      );
      allow get: if isSignedIn() && (
        getUid() == resource.data.tenantId || 
        getUid() == resource.data.landlordId
      );
      allow create: if isSignedIn() && (
        request.resource.data.senderId == getUid() &&
        (getUid() == request.resource.data.tenantId || getUid() == request.resource.data.landlordId)
      );
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId ||
        getUid() == resource.data.reportedBy
      );
      allow get: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId ||
        getUid() == resource.data.reportedBy
      );
      allow create: if isSignedIn();
      allow update: if isLandlord(resource.data) || isTenant(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId ||
        getUid() == resource.data.propertyId
      );
      allow read: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId ||
        getUid() == resource.data.propertyId
      );
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId
      );
      allow read: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId
      );
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId
      );
      allow get: if isSignedIn() && (
        getUid() == resource.data.landlordId ||
        getUid() == resource.data.tenantId
      );
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isSignedIn();
    }

    match /expenses/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }

    match /checklists/{id} {
      allow list: if isSignedIn() && getUid() == resource.data.landlordId;
      allow read, write: if isSignedIn() && getUid() == resource.data.landlordId;
    }
  }
}
