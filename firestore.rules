rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      // Allow read/write if the user is the owner of the tenant record.
      allow read, write: if isSignedIn() && (resource == null || isOwner(resource.data)) && (request.resource == null || isOwner(request.resource.data));

      match /screenings/{screeningId} {
        allow read, write: if isSignedIn() && (resource == null || isOwner(resource.data)) && (request.resource == null || isOwner(request.resource.data));
      }
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      allow read, write: if isSignedIn() && (resource == null || isOwner(resource.data)) && (request.resource == null || isOwner(request.resource.data));

      // Sub-collections: maintenanceLogs, inspections, documents, expenses, rentPayments, checklists
      match /{subcollection}/{docId=**} {
        allow read, write: if isSignedIn() && (resource == null || isOwner(resource.data)) && (request.resource == null || isOwner(request.resource.data));
      }
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow read, write: if isSignedIn() && (resource == null || isOwner(resource.data)) && (request.resource == null || isOwner(request.resource.data));
    }

    // --- Collection Group Rules (Critical for Performance & Global Queries) ---
    match /{path=**}/maintenanceLogs/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/rentPayments/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/expenses/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/checklists/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}