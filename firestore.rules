rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER DATA
    match /users/{userId} {
      // Users can get and update their own user profile document.
      allow get, update: if request.auth.uid == userId;
      
      // Allow users to manage tenants within their own sub-collection.
      match /tenants/{tenantId} {
        // A user can list their own tenants.
        allow list: if request.auth.uid == userId;
        
        // A user can get, create, update, or delete a specific tenant document they own.
        allow get, update, delete: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId && request.resource.data.ownerId == request.auth.uid;
      }
      
      // Users can only manage screenings for their own tenants.
      match /tenants/{tenantId}/screenings/{screeningId} {
         allow read, write: if request.auth.uid == userId;
      }
    }

    // PROPERTIES collection
    match /properties/{propertyId} {
      // Allow authenticated users to get or list properties.
      // The application code is responsible for filtering these lists to only show the user's own properties.
      allow get, list: if request.auth != null;

      // Only the owner can create, update, or delete a property.
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if resource.data.ownerId == request.auth.uid;
      
      // PROPERTY SUBCOLLECTIONS (Maintenance, Inspections, Documents, etc.)
      match /{subcollection}/{docId} {
         // To read or write to a property's subcollection, the user must own the parent property.
         allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      }
    }
    
    // CONTRACTORS collection
    match /contractors/{contractorId} {
       // Allow authenticated users to get or list contractors.
       // The application will filter this list to show only the user's contractors.
       allow get, list: if request.auth != null;

       // Only the owner can create, update, or delete their own contractors.
       allow create: if request.resource.data.ownerId == request.auth.uid;
       allow update, delete: if resource.data.ownerId == request.auth.uid;
    }
  }
}
