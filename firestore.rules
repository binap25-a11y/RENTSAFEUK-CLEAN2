rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      // Landlords only access their own profile root
      allow get, create, update, delete: if isOwner(userProfileId);
      allow list: if false;

      match /properties/{propertyId} {
        // Path-based ownership authorization for all property records
        allow read, write: if isOwner(userProfileId);

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userProfileId);
          // Allow assigned tenant access
          allow read: if isSignedIn() && (
            resource.data.reportedBy == request.auth.uid ||
            resource.data.tenantEmail == request.auth.token.email
          );
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userProfileId);
          // Allow assigned tenant access
          allow read: if isSignedIn() && resource.data.tenantEmail == request.auth.token.email;
        }

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userProfileId);
          // Allow verified resident to read their own assignment
          allow read: if isSignedIn() && resource.data.email == request.auth.token.email;

          match /messages/{messageId} {
            allow read, write: if isOwner(userProfileId);
            // Access for parties involved in the thread
            allow read: if isSignedIn() && (
                resource.data.senderId == request.auth.uid ||
                resource.data.recipientEmail == request.auth.token.email
            );
          }
          
          match /screenings/{screeningId} {
            allow read, write: if isOwner(userProfileId);
          }
          
          match /checklists/{checklistId} {
            allow read, write: if isOwner(userProfileId);
          }
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userProfileId);
          allow read: if isSignedIn() && resource.data.tenantEmail == request.auth.token.email;
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userProfileId);
        }
        
        match /expenses/{expenseId} {
          allow read, write: if isOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userProfileId);
      }
    }

    // --- Specialized Collection Group Rules for Discovery & Multi-Role Access ---

    match /{path=**}/tenants/{tenantId} {
      // Unified discovery rule for both Landlords and Tenants
      allow list, get: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        (resource.data.userId == request.auth.uid)
      );
    }

    match /{path=**}/messages/{messageId} {
      // Identity-based access for secure messaging channels
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientEmail == request.auth.token.email
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Access for reporter, landlord, or property resident
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid ||
        resource.data.tenantEmail == request.auth.token.email
      );
    }
  }
}
