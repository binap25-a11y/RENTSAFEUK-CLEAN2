rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      match /screenings/{screeningId} {
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Sub-collections: maintenanceLogs, inspections, documents, expenses, rentPayments, checklists
      match /{subcollection}/{docId=**} {
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // --- Collection Group Rules (Critical for Performance & Global Queries) ---
    match /{path=**}/maintenanceLogs/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/rentPayments/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/expenses/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/checklists/{id} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}