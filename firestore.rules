
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    /**
     * Discovery rules for Tenants and Landlords.
     * These rules allow the application to identify a user's role across the entire platform.
     */
    match /{path=**}/tenants/{tenantId} {
      // Allows residents to find their own identity records via email discovery
      // Allows landlords to list their own tenants across properties via userId discovery
      allow list, get: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.senderId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.reportedBy == request.auth.token.name ||
        resource.data.reportedBy == request.auth.token.email.lower()
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * Recursive portfolio oversight for Landlords.
       * Grants the property owner full read/write access to all nested data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
