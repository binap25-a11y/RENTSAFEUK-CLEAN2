
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Authorized Discovery) ---
    
    match /{path=**}/tenants/{tenantId} {
      // Allow role-discovery and oversight list operations.
      // Combined rule helps the query engine authorize collectionGroup searches.
      allow list: if isSignedIn() && (
        resource.data.email.lower() == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
      
      // Individual document access
      allow get: if isSignedIn() && (
        resource.data.email.lower() == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.senderId == request.auth.uid);
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.reportedBy == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.reportedBy == request.auth.uid);
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
