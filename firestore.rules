rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v5.0
     * Optimized for high-speed identity discovery and query-compatible authorization.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Landlord check: verifies if user owns the record or is the landlord of the linked asset
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '')
      );
    }

    // Tenant check: authorizes access via UID or verified email handshake
    // Uses .lower() for robust cross-provider identity mapping
    function isTenant(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      return isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        uid in data.get('activeTenantUids', []) ||
        (email != null && email.lower() == data.get('email', '').lower()) ||
        (email != null && email.lower() == data.get('tenantEmail', '').lower()) ||
        (email != null && (email.lower() in data.get('tenantEmails', [])))
      );
    }

    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // IDENTITY DISCOVERY: Allow any signed-in user to query the registry.
      // High-speed list access is authorized for all authenticated users to facilitate the handshake.
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      // HANDSHAKE: Allow verified residents to link their UID to the registry record.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // QUERY OPTIMIZATION: Allow high-speed listing for landlords and portal discovery.
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      // HANDSHAKE: Allow residents to link their account to the property asset.
      // Critically allows the atomic transition from email-auth to UID-auth.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Ledger Collections ---
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    // --- Global Fallback ---
    match /{path=**} {
      allow read, write: if isSignedIn() && (
        (resource != null && isLandlord(resource.data)) ||
        (request.resource != null && isLandlord(request.resource.data))
      );
    }
  }
}