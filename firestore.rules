rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- USER DATA: Explicit Rules ---
    // This section explicitly grants permissions for the tenants sub-collection
    // to avoid any ambiguity with recursive wildcards.
    
    // Allow a user to read/update their own user document.
    match /users/{userId} {
      allow get, update: if request.auth.uid == userId;
    }
    
    // Allow a user to LIST their own tenants collection.
    // This is the specific rule that fixes the error on the property details page.
    match /users/{userId}/tenants {
      allow list, create: if request.auth.uid == userId;
    }

    // Allow a user to access individual tenant documents they own.
    match /users/{userId}/tenants/{tenantId} {
      allow get, update, delete: if request.auth.uid == userId;
    }
    
    // Allow a user to access screening documents for their own tenants.
    match /users/{userId}/tenants/{tenantId}/screenings/{screeningId} {
        allow read, write: if request.auth.uid == userId;
    }

    // --- TOP-LEVEL COLLECTIONS ---

    // PROPERTIES
    // Allow an authenticated user to LIST their own properties.
    // The client-side query MUST filter by ownerId.
    match /properties {
      allow list: if request.auth != null;
    }
    match /properties/{propertyId} {
      // Allow a user to get, update, or delete their OWN property document.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      // Allow a user to create a property if the ownerId matches their UID.
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // CONTRACTORS
    // Allow an authenticated user to LIST their own contractors.
    // The client-side query must filter by ownerId.
    match /contractors {
       allow list: if request.auth != null;
    }
    match /contractors/{contractorId} {
      // Allow a user to get, update, or delete their OWN contractor document.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      // Allow a user to create a contractor if the ownerId matches their UID.
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- PROPERTY SUB-COLLECTIONS ---
    // This single rule secures all sub-collections under any property.
    // To read or write to a property's subcollection, the user must own the parent property.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }
  }
}
