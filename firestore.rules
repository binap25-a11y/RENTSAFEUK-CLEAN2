rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v25.0
     * Optimized for high-speed Discovery, atomic Identity Handshake, and Secure Messaging.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // DISCOVERY: Validates identity bridge via normalized email or account UID.
    // Optimized for direct string comparison to satisfy the Firestore query engine.
    function isRelated(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      return isSignedIn() && (
        uid == data.get('landlordId', '') || 
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') || 
          (data.get('tenantEmails', []) is list && email in data.get('tenantEmails', []))
        ))
      );
    }

    function isLandlord(data) {
      return isSignedIn() && request.auth.uid == data.get('landlordId', '');
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Allow discovery list for all signed-in users (query will be filtered by email or landlordId)
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to update their own verification status if they match the registry email.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (request.auth.token.email == resource.data.email && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Allow discovery list for all signed-in users (query will be filtered by landlordId or tenantEmail)
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to link their account to the property bridge if they match the registry email.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (request.auth.token.email == resource.data.tenantEmail && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Explicitly allow list if the user is a participant in the conversation (indexed query check)
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid);
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }
    
    match /screenings/{id} {
      allow list: if isSignedIn();
      allow read: if isLandlord(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /checklists/{id} {
      allow list: if isSignedIn();
      allow read: if isLandlord(resource.data);
      allow write: if isLandlord(resource.data);
    }
  }
}