
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v18.0
     * Optimized for high-performance chronological messaging.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : "";
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /residents/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail()
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (userEmail() != "" && resource.data.get("tenantEmail", "").lower() == userEmail())
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow get, list: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email.lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.email.lower() == userEmail()
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.get('tenantUid', '') ||
        resource.data.get('tenantEmail', '').lower() == userEmail() ||
        (resource.data.tenantId != null && exists(/databases/$(database)/documents/tenants/$(resource.data.tenantId)) && 
          (get(/databases/$(database)/documents/tenants/$(resource.data.tenantId)).data.userId == request.auth.uid ||
           get(/databases/$(database)/documents/tenants/$(resource.data.tenantId)).data.email.lower() == userEmail())
        )
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid
      );
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow get, list: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedBy == request.auth.uid ||
        resource.data.get('tenantEmail', '').lower() == userEmail()
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Documents ---
    match /documents/{id} {
      allow get, list: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.propertyId != null
      );
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- General Audits ---
    match /contractors/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
    match /inspections/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
    match /screenings/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
    match /checklists/{id} { allow read, write, list: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid); }
  }
}
