rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v5.0
     * Optimized for Static Query Verification and Case-Insensitive Discovery.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.get('email', '').lower();
    }

    // Helper to check if the user is the landlord of the record
    function isLandlord(data) {
      return isSignedIn() && request.auth.uid == data.get('landlordId', '');
    }

    // Helper to check if the user is the tenant of the record
    function isTenant(data) {
      let email = getEmail();
      let uid = request.auth.uid;
      return isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        (email != "" && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '')
        ))
      );
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // Discovery: Authorized via verified email token
      allow list: if isSignedIn() && (
        getEmail() == resource.data.get('email', '') ||
        request.auth.uid == resource.data.get('userId', '') ||
        request.auth.uid == resource.data.get('landlordId', '')
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID if they match the registry email
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (getEmail() == resource.data.get('email', '') && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // Discovery: Authorized via verified email token
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.get('landlordId', '') || 
        getEmail() == resource.data.get('tenantEmail', '')
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      
      // HANDSHAKE: Allow residents to link their UID to the property bridge
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (getEmail() == resource.data.get('tenantEmail', '') && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Secure Messaging Ledger ---
    match /messages/{id} {
      // Optimized for high-speed indexed chat queries
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.get('tenantId', '') || 
        request.auth.uid == resource.data.get('landlordId', '')
      );
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.get('senderId', '') || 
        request.auth.uid == resource.data.get('tenantId', '') || 
        request.auth.uid == resource.data.get('landlordId', '')
      );
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid);
      allow update, delete: if false;
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.get('landlordId', '') || 
        request.auth.uid == resource.data.get('tenantId', '') ||
        request.auth.uid == resource.data.get('reportedBy', '')
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow create: if isSignedIn();
      allow update: if isLandlord(resource.data) || isTenant(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.get('landlordId', '') || 
        request.auth.uid == resource.data.get('tenantId', '') ||
        isTenant(resource.data)
      );
      allow read: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isLandlord(resource.data);
      allow read: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.get('landlordId', '') || 
        request.auth.uid == resource.data.get('tenantId', '')
      );
      allow get: if isLandlord(resource.data) || isTenant(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }

    match /expenses/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }
    
    match /screenings/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }

    match /checklists/{id} {
      allow list, read, write: if isLandlord(resource.data) || (isSignedIn() && request.resource.data.landlordId == request.auth.uid);
    }
  }
}