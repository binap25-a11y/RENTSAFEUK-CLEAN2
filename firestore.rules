
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Group Rules (Cross-Portfolio Discovery) ---
    
    /**
     * Residents discovery query requires proof-of-identity filter.
     * Note: We expect emails to be stored in lowercase in the database.
     */
    match /{path=**}/tenants/{tenantId} {
      // Allow tenant to find their own record
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      
      // Allow get if email matches or landlord owns the record
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    // Secure Messenger discovery
    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.senderId == request.auth.uid
      );
    }

    // Maintenance discovery for residents
    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.reportedBy == request.auth.token.name ||
        resource.data.reportedBy == request.auth.token.email
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /** 
       * Recursive portfolio oversight for Landlords.
       * Grants the property owner full read/write access to all nested data.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }

      match /properties/{propertyId} {
        // Tenants can view property metadata if they have an active record here
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          match /messages/{messageId} {
            allow read, write: if isSignedIn() && (
              get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email
            );
          }
        }
      }
    }
  }
}
