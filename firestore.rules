
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE
     * Optimized for Static Query Prove-ability and Actor-Based Authorization.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return (isSignedIn() && "email" in request.auth.token && request.auth.token.email != null) 
        ? request.auth.token.email.lower() 
        : "";
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /residents/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      // STATICALLY PROVABLE LIST: Evaluates specific filter paths
      allow list: if isSignedIn() && (
        (request.query.filters.get('landlordId', []) == [request.auth.uid]) ||
        (request.auth.uid in request.query.filters.get('activeTenantUids', [])) ||
        (userEmail() != "" && request.query.filters.get('tenantEmail', []) == [userEmail()]) ||
        (userEmail() != "" && userEmail() in request.query.filters.get('tenantEmails', []))
      );
      
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get("activeTenantUids", []) ||
        resource.data.get("tenantEmail", "").lower() == userEmail() ||
        userEmail() in resource.data.get("tenantEmails", [])
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // Identity Handshake Bridge
        (userEmail() != "" && resource.data.get("tenantEmail", "").lower() == userEmail())
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && (
        (request.query.filters.get('landlordId', []) == [request.auth.uid]) ||
        (request.query.filters.get('userId', []) == [request.auth.uid]) ||
        (userEmail() != "" && request.query.filters.get('email', []) == [userEmail()])
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.get("userId", "") == request.auth.uid ||
        resource.data.get("email", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (userEmail() != "" && resource.data.get("email", "").lower() == userEmail())
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        (request.query.filters.get('landlordId', []) == [request.auth.uid]) ||
        (request.query.filters.get('tenantId', []) == [request.auth.uid]) ||
        (request.query.filters.get('reportedBy', []) == [request.auth.uid])
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.get('reportedBy', '') == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get("reportedBy", "") == request.auth.uid
      );
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        (request.query.filters.get('tenantId', []) == [request.auth.uid]) ||
        (request.query.filters.get('landlordId', []) == [request.auth.uid])
      );
      
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Documents ---
    match /documents/{id} {
      allow list: if isSignedIn() && (
        (request.query.filters.get('landlordId', []) == [request.auth.uid]) ||
        (request.query.filters.get('propertyId', []) != [])
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        isSignedIn()
      );
      
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    
    match /expenses/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- General Audits ---
    match /contractors/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /screenings/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /checklists/{id} {
      allow list: if isSignedIn() && (request.query.filters.get('landlordId', []) == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
  }
}
