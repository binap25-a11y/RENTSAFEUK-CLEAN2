rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly check for data ownership to support filtered queries
    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      // Use read (get + list) and check resource data for strict portfolio scoping
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);

      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
        allow write: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      }
    }

    match /tenants/{tenantId} {
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
      
      match /{allSubcollections=**} {
        allow read: if isOwner(resource.data);
        allow create: if isOwner(request.resource.data);
        allow update, delete: if isOwner(resource.data);
      }
    }

    match /contractors/{contractorId} {
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }
  }
}