rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL SECURITY HELPERS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- TOP-LEVEL STATICALLY PROVABLE RULES (OPTIMIZED FOR INSTANT DISCOVERY) ---
    // Rules must match query filters exactly for index verification.
    
    match /{path=**}/tenants/{tenantId} {
      // Optimized for exact email matching queries.
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow list, get: if isSignedIn();
       allow create: if isSignedIn();
    }

    // --- CORE HIERARCHICAL DATA ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Residents read assigned property details for hub context.
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          // Resident-specific read access via lower-cased normalization
          allow get: if isSignedIn() && (
            resource.data.email == request.auth.token.email.lower() ||
            resource.data.userId == request.auth.uid
          );

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower());
          }

          match /screenings/{screeningId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower();
          }
          
          match /checklists/{checklistId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email == request.auth.token.email.lower();
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow get, list: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
