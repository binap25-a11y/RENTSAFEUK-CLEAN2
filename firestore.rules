rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- USER DATA ---
    match /users/{userId} {
      // A user can read and update their own user document.
      allow get, update: if request.auth.uid == userId;
    }
    
    match /users/{userId}/tenants {
      // A user can LIST their own tenants collection. THIS IS THE KEY FIX.
      // A user can CREATE new tenants in their own collection.
      allow list, create: if request.auth.uid == userId;
    }

    match /users/{userId}/tenants/{tenantId} {
      // A user can GET, UPDATE, and DELETE their own individual tenant documents.
      allow get, update, delete: if request.auth.uid == userId;
    }
    
    match /users/{userId}/tenants/{tenantId}/screenings/{screeningId} {
      // A user has full access to screening documents for tenants they own.
      allow read, write: if request.auth.uid == userId;
    }

    // --- TOP-LEVEL PROPERTIES COLLECTION ---
    match /properties {
      // Allow a user to LIST properties. The client query MUST filter by ownerId.
      allow list: if request.auth != null;
    }

    match /properties/{propertyId} {
      // Allow a user to GET, UPDATE, or DELETE a property document they own.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      // Allow a user to CREATE a property document if the ownerId in the new data is their own UID.
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- TOP-LEVEL CONTRACTORS COLLECTION ---
     match /contractors {
       // Allow a user to LIST contractors. The client query MUST filter by ownerId.
       allow list: if request.auth != null;
    }
    match /contractors/{contractorId} {
      // Allow a user to GET, UPDATE, or DELETE a contractor document they own.
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      // Allow a user to CREATE a contractor document if the ownerId is their own UID.
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- PROPERTY SUB-COLLECTIONS ---
    // This rule secures all sub-collections (maintenance, inspections, etc.) under any property.
    // To read or write, the user must own the parent property document.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }
  }
}
