rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Collection ---
    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // --- Tenants Collection ---
    match /tenants {
      allow list: if request.auth != null && request.query.filters.ownerId == request.auth.uid;
      allow create: if request.auth.uid == request.resource.data.ownerId;
    }
    
    match /tenants/{tenantId} {
        allow get, update, delete: if request.auth.uid == get(path).data.ownerId;

        match /screenings/{screeningId} {
            allow read, write: if request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
        }
    }

    // --- Properties Collection ---
    match /properties {
      allow list: if request.auth != null && request.query.filters.ownerId == request.auth.uid;
      allow create: if request.auth.uid == request.resource.data.ownerId;
    }
    
    match /properties/{propertyId} {
      allow get: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if resource.data.ownerId == request.auth.uid;

      match /{subcollection}/{docId=**} {
        allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      }
    }

    // --- Contractors Collection ---
    match /contractors {
      allow list: if request.auth != null && request.query.filters.ownerId == request.auth.uid;
      allow create: if request.auth.uid == request.resource.data.ownerId;
    }

    match /contractors/{contractorId} {
      allow get, update, delete: if request.auth.uid == get(path).data.ownerId;
    }

    // --- Collection Group Rules (Critical for Performance) ---
    // These allow the app to query across all properties for a single owner in one request.
    match /{path=**}/maintenanceLogs/{id} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/inspections/{id} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/documents/{id} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/rentPayments/{id} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /{path=**}/expenses/{id} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
  }
}