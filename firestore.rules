rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL SECURITY HELPERS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- TOP-LEVEL DISCOVERY RULES (CRITICAL FOR HANDSHAKE PERFORMANCE) ---
    // These rules are placed here to ensure the discovery queries (collectionGroup)
    // resolve instantly even before the full profile document is parsed.
    
    match /{path=**}/tenants/{tenantId} {
      allow read: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower()) ||
        resource.data.userId == request.auth.uid
      );
      
      // Allow the tenant to update their own verification status during the handshake
      // restrict them to ONLY identity-linking fields.
      allow update: if isSignedIn() && request.auth.token.email != null 
                    && resource.data.email.lower() == request.auth.token.email.lower()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedDate', 'userId', 'verified']);
    }

    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn();
    }

    // --- CORE HIERARCHICAL PORTFOLIO DATA ---

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Residents can read the property details they are assigned to
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          
          // Resident-specific access via path-based verification
          allow get: if isSignedIn() && (
            (request.auth.token.email != null && resource.data.email.lower() == request.auth.token.email.lower()) ||
            resource.data.userId == request.auth.uid
          );

          // Explicitly allow the tenant to perform the identity handshake update at the specific path
          allow update: if isSignedIn() && request.auth.token.email != null 
                        && resource.data.email.lower() == request.auth.token.email.lower()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedDate', 'userId', 'verified']);

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && request.auth.token.email != null && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == request.auth.token.email.lower());
          }

          match /screenings/{screeningId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && request.auth.token.email != null && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == request.auth.token.email.lower();
          }
          
          match /checklists/{checklistId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && request.auth.token.email != null && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == request.auth.token.email.lower();
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow read: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}