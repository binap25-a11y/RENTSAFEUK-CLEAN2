
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v6.5
     * Index deployment re-synchronized for high-performance messaging registry.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : "";
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /residents/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail()
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get('activeTenantUids', []) ||
        resource.data.get('tenantEmail', "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (userEmail() != "" && resource.data.get("tenantEmail", "").lower() == userEmail())
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email.lower() == userEmail()
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.email.lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (userEmail() != "" && resource.data.email.lower() == userEmail()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']) && resource.data.email.lower() == userEmail())
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedBy == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedBy == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.landlordId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Documents ---
    match /documents/{id} {
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.propertyId != null
      );
      
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.propertyId != null
      );
      
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- General Audits ---
    match /contractors/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    match /inspections/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    match /screenings/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    match /checklists/{id} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}
