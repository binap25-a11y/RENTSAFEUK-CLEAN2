
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v8.0
     * Optimized for high-speed discovery and robust identity handshake.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Landlord check: verifies if user owns the record or is the landlord of the linked asset
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '')
      );
    }

    // Tenant check: authorizes access via UID or verified email handshake
    function isTenant(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      return isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        uid in data.get('activeTenantUids', []) ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') || 
          email in data.get('tenantEmails', [])
        ))
      );
    }

    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // IDENTITY DISCOVERY: Allow all signed-in users to list for handshake discovery.
      // This is query-compatible because it doesn't depend on resource.data.
      allow list: if isSignedIn(); 
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to link their UID if their email matches.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      // QUERY OPTIMIZATION: Allow listing for all signed-in users to support portal discovery.
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to link their account to the property asset.
      // This explicitly allows the critical email -> UID transition.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }
  }
}
