rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      // Landlords only access their own profile root
      allow get: if isOwner(userProfileId);
      allow list: if false;
      
      allow create: if isOwner(userProfileId);
      allow update: if isOwner(userProfileId);
      allow delete: if isOwner(userProfileId);

      match /properties/{propertyId} {
        // Comprehensive ownership-based access for all property-related data
        allow get, list, create, update, delete: if isOwner(userProfileId);

        match /maintenanceLogs/{logId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }

        match /documents/{documentId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }

        match /tenants/{tenantId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);

          match /messages/{messageId} {
            allow get, list, create, update, delete: if isOwner(userProfileId);
          }
          
          match /screenings/{screeningId} {
            allow get, list, create, update, delete: if isOwner(userProfileId);
          }
        }

        match /rentPayments/{paymentId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }

        match /checklists/{checklistId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }
        
        match /inspections/{inspectionId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }
        
        match /expenses/{expenseId} {
          allow get, list, create, update, delete: if isOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow get, list, create, update, delete: if isOwner(userProfileId);
      }
    }

    // --- Optimized collectionGroup Rules for cross-portfolio discovery ---

    match /{path=**}/tenants/{tenantId} {
      // Identity-based discovery for Residents
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      
      // Ownership-based oversight for Landlords
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }
  }
}