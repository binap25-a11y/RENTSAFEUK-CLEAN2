rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      // Allow creation if the ownerId matches the authenticated user
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Allow reading (get/list), updating, and deleting if the user is the owner
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Rules for all sub-collections (Maintenance, Inspections, etc.)
      match /{allSubcollections=**} {
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      match /{allSubcollections=**} {
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}