rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safely retrieves the lowercased email from the authentication token
    function getEmail() {
      return (isSignedIn() && request.auth.token.email != null) ? request.auth.token.email.toLower() : "";
    }

    // --- Optimized Collection Group Rules for Discovery (Top Level) ---
    // These must remain at the top level to allow global collectionGroup queries 
    // to succeed across all user profile branches.

    match /{path=**}/tenants/{tenantId} {
      allow list, get: if isSignedIn() && (
        resource.data.email == getEmail() ||
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientEmail == getEmail()
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid ||
        resource.data.tenantEmail == getEmail()
      );
    }

    // --- User Profile Hierarchy ---

    match /userProfiles/{userProfileId} {
      // Landlords only access their own profile root
      allow get, create, update, delete: if isOwner(userProfileId);
      allow list: if false;

      match /properties/{propertyId} {
        // Path-based ownership authorization for all property records
        allow read, write: if isOwner(userProfileId);
        
        // ALLOWANCE: Tenants need to 'get' the property document to see address/rent info in their portal
        // once they have discovered the property path via the tenants collection group.
        allow get: if isSignedIn();

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userProfileId);
          // Allow assigned tenant access via email match or reporter ID
          allow read: if isSignedIn() && (
            resource.data.reportedBy == request.auth.uid ||
            resource.data.tenantEmail == getEmail()
          );
          // Tenants can create logs for their property
          allow create: if isSignedIn();
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userProfileId);
          // Allow assigned tenant access via email match
          allow read: if isSignedIn() && resource.data.tenantEmail == getEmail();
        }

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userProfileId);
          // Allow verified tenant to read their own assignment record
          allow read: if isSignedIn() && resource.data.email == getEmail();

          match /messages/{messageId} {
            allow read, write: if isOwner(userProfileId);
            // Access for parties involved in the thread
            allow read: if isSignedIn() && (
                resource.data.senderId == request.auth.uid ||
                resource.data.recipientEmail == getEmail()
            );
            allow create: if isSignedIn();
          }
          
          match /screenings/{screeningId} {
            allow read, write: if isOwner(userProfileId);
            // Tenants can see their own screening results
            allow read: if isSignedIn();
          }
          
          match /checklists/{checklistId} {
            allow read, write: if isOwner(userProfileId);
          }
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userProfileId);
          allow read: if isSignedIn() && resource.data.tenantEmail == getEmail();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userProfileId);
          allow read: if isSignedIn();
        }
        
        match /expenses/{expenseId} {
          allow read, write: if isOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userProfileId);
      }
    }
  }
}