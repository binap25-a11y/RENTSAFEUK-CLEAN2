
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v9.0
     * Optimized for Static Rule-Query Verification and Actor-Based Determinism.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.get("email", "").lower();
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /residents/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      // PROVABLE LIST: Decomposed for query optimizer
      allow list: if isSignedIn() && (
        (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId) ||
        (request.query.filters.has('activeTenantUids') && request.auth.uid in request.query.filters.activeTenantUids) ||
        (request.query.filters.has('tenantEmail') && userEmail() != "" && userEmail() in request.query.filters.tenantEmail)
      );
      
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get("activeTenantUids", []) ||
        resource.data.get("tenantEmail", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes Residents to link UID on first login
        (resource.data.get("tenantEmail", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && (
        (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId) ||
        (request.query.filters.has('userId') && request.auth.uid in request.query.filters.userId) ||
        (request.query.filters.has('email') && userEmail() != "" && userEmail() in request.query.filters.email)
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.get("userId", "") == request.auth.uid ||
        resource.data.get("email", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes UID linking
        (resource.data.get("email", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId) ||
        (request.query.filters.has('tenantId') && request.auth.uid in request.query.filters.tenantId) ||
        (request.query.filters.has('reportedBy') && request.auth.uid in request.query.filters.reportedBy)
      );
      
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get("reportedBy", "") == request.auth.uid
      );
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        (request.query.filters.has('tenantId') && request.auth.uid in request.query.filters.tenantId) ||
        (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId)
      );
      
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Documents ---
    match /documents/{id} {
      allow list: if isSignedIn() && (
        (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId) ||
        (request.query.filters.has('propertyId'))
      );
      
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow list: if isSignedIn() && (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    
    match /expenses/{id} {
      allow list: if isSignedIn() && (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- General Fallbacks ---
    match /contractors/{id} {
      allow list: if isSignedIn() && (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow list: if isSignedIn() && (request.query.filters.has('landlordId') && request.auth.uid in request.query.filters.landlordId);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
  }
}
