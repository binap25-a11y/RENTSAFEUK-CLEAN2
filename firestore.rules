
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Landlord check based on explicit landlordId field
    function isLandlordOf(data) {
      return isSignedIn() && (data.landlordId == request.auth.uid || data.userId == request.auth.uid);
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- 2. Properties Collection ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- 3. Tenants Collection ---
    match /tenants/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.email == request.auth.token.email.lower()
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- 4. Shared Portfolio Collections (Repairs, Documents, etc.) ---
    match /{collectionName}/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedBy == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      
      // Explicit constraints for create operations to ensure landlordId is present
      allow create: if isSignedIn();
    }
  }
}
