rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      // Landlords only access their own profile root
      allow get, create, update, delete: if isOwner(userProfileId);
      allow list: if false;

      match /properties/{propertyId} {
        // Path-based ownership authorization for all property records
        allow read, write: if isOwner(userProfileId);

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userProfileId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userProfileId);
        }

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userProfileId);

          match /messages/{messageId} {
            allow read, write: if isOwner(userProfileId);
          }
          
          match /screenings/{screeningId} {
            allow read, write: if isOwner(userProfileId);
          }
          
          match /checklists/{checklistId} {
            allow read, write: if isOwner(userProfileId);
          }
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userProfileId);
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userProfileId);
        }
        
        match /expenses/{expenseId} {
          allow read, write: if isOwner(userProfileId);
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userProfileId);
      }
    }

    // --- Specialized Collection Group Rules for Discovery ---
    // Rule provability is critical for high-performance role discovery.

    match /{path=**}/tenants/{tenantId} {
      // Allow tenant role discovery based on email (provable query filter)
      allow list: if isSignedIn() && request.auth.token.email != null && resource.data.email == request.auth.token.email;
      
      // Allow read access for the verified resident
      allow get: if isSignedIn() && request.auth.token.email != null && resource.data.email == request.auth.token.email;
      
      // Allow access for the asset owner (landlord)
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/messages/{messageId} {
      // Access for parties involved in the secure channel
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Access for reporter (tenant) or owner (landlord)
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }
  }
}
