rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- USER DATA ---
    // This single rule grants a user full read/write access to their own
    // user document and ALL of its subcollections (like tenants, screenings).
    // This is the most robust way to handle user-owned nested data.
    match /users/{userId}/{path=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- TOP-LEVEL COLLECTIONS ---

    // This rule allows a client to LIST properties, but the client-side query
    // MUST be constrained with `where('ownerId', '==', request.auth.uid)`.
    match /properties {
      allow list: if request.auth != null;
    }

    // This rule allows GET, CREATE, UPDATE, and DELETE operations on individual
    // property documents, checking the ownerId for security.
    match /properties/{propertyId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // This rule allows a client to LIST contractors, constrained by ownerId.
    match /contractors {
      allow list: if request.auth != null;
    }

    // This rule handles individual contractor documents.
    match /contractors/{contractorId} {
      allow get, update, delete: if resource.data.ownerId == request.auth.uid;
      allow create: if request.resource.data.ownerId == request.auth.uid;
    }

    // --- PROPERTY SUB-COLLECTIONS (Maintenance, Inspections, etc.) ---
    // This single rule secures all sub-collections under any property
    // by checking the ownerId of the parent property document.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }
  }
}
