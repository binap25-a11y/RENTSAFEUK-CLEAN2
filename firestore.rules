
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Landlords have full recursive access to their own profile and nested portfolio data.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;

      // Portfolio Collections (Properties, Contractors, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Critical for multi-role discovery and portal access.

    match /{path=**}/tenants/{tenantId} {
      // Allow discovery via email for the "Role Check" and Tenant Portal.
      // We explicitly check list vs get to ensure query constraints are satisfied.
      allow list: if isSignedIn() && (
        (request.auth.token.email != null && request.query.limit <= 10) ||
        (request.auth.uid != null)
      );
      
      allow get: if isSignedIn() && (
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      // Landlords and assigned tenants can view logs.
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null && resource.data.reportedBy == request.auth.token.email)
      );
      // Anyone signed in can create a log (it will be matched to their property context in code).
      allow create: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow list, get: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid) ||
        (request.auth.token.email != null) // Access controlled by property visibility
      );
    }

    match /{path=**}/messages/{messageId} {
      // Direct messaging is permitted for all involved parties.
      allow list, get, create: if isSignedIn();
    }

    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/expenses/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    match /{path=**}/rentPayments/{id} {
      allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }
  }
}
