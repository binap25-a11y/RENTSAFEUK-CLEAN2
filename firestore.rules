rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isOwner(ownerId) {
      return request.auth.uid == ownerId;
    }

    function isParentOwner(parentPath) {
      return isOwner(get(parentPath).data.ownerId);
    }
    
    // USER data can only be read/written by the user themselves
    match /users/{userId} {
      // Allow user to get, update, delete their own profile document
      allow get, update, delete: if isOwner(userId);
      // Allow a user to create their own profile document
      allow create: if isOwner(userId);

      // Rule for LISTING tenants collection
      match /tenants {
        allow list: if isOwner(userId);
      }

      // Rule for GETTING/WRITING individual tenant documents
      match /tenants/{tenantId} {
        allow get, create, update, delete: if isOwner(userId);
        
        // SCREENINGS are owned by the user via the tenant
        match /screenings/{screeningId} {
            // A user can read/write screenings for their own tenants
            allow read, write: if isOwner(userId);
        }
      }
    }
    
    // PROPERTIES can only be managed by their owner
    match /properties/{propertyId} {
      allow read, update, delete: if isOwner(get(resource.data.ownerId));
      allow create: if isOwner(request.resource.data.ownerId);

      // PROPERTY SUBCOLLECTIONS can only be managed by the property owner
      match /{subcollection}/{docId} {
        allow read, write: if isParentOwner(/databases/$(database)/documents/properties/$(propertyId));
      }
    }
    
    // CONTRACTORS can only be managed by their owner
    match /contractors/{contractorId} {
       allow read, update, delete: if isOwner(resource.data.ownerId);
       allow create: if isOwner(request.resource.data.ownerId);
    }
  }
}
