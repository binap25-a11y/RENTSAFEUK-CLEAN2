rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This rule allows any authenticated user to read and write to the
    // entire database. This is intended for development and debugging purposes only.
    // Replace with more secure rules before moving to production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
