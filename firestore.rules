rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Properties Collection (Root and Sub-collections) ---
    match /properties/{propertyId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Maintenance Logs, Inspections, Documents, Expenses, Rent Payments, Checklists
      match /{allSubcollections=**} {
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      match /{allSubcollections=**} {
        allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
    }

    // --- Contractors Collection ---
    match /contractors/{contractorId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}