rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write to their own user document.
    match /users/{userId} {
      allow read, update, create: if request.auth != null && request.auth.uid == userId;
    }

    // This rule handles all sub-collections (e.g., maintenanceLogs, inspections, documents under a property).
    // It allows access if the user owns the parent document in the top-level collection.
    match /{collection}/{docId}/{subcollection}/{subDocId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/$(collection)/$(docId)).data.ownerId == request.auth.uid;
    }

    // This generic rule applies to all top-level collections (properties, tenants, contractors).
    // It must come after more specific rules (like /users).
    match /{collection}/{docId} {
       // Allow read, update, and delete only if the user is the owner of the document.
       allow read, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
       
       // Allow create only if the user is setting themselves as the owner.
       allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
