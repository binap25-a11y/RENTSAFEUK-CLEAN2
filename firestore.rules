rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    //-------------------------------------------------------------------------
    // Top-Level Collection Rules
    //-------------------------------------------------------------------------

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if false; // Explicitly deny listing all users
      allow create: if isOwner(userId);
    }

    match /properties/{propertyId} {
      // A user can GET a specific property document if they are the owner.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // A user can LIST (query) properties.
      // SECURITY: Client-side queries MUST enforce security by including
      // a "where('ownerId', '==', request.auth.uid)" clause.
      allow list: if isSignedIn();

      // Users can update or delete their own properties.
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // Users can create new properties, ensuring they set themselves as the owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // A user can GET a specific tenant document if they are the owner.
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // A user can LIST (query) tenants.
      // SECURITY: Client-side queries MUST enforce security by including
      // a "where('ownerId', '==', request.auth.uid)" clause.
      allow list: if isSignedIn();

      // Users can update or delete their own tenant records.
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // Users can create new tenant records, ensuring they set themselves as the owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    //-------------------------------------------------------------------------
    // Collection Group Rules
    //-------------------------------------------------------------------------

    // This single rule block securely handles all access to 'maintenanceLogs' collections.
    match /{path=**}/maintenanceLogs/{logId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // This single rule block securely handles all access to 'expenses' collections.
    match /{path=**}/expenses/{expenseId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
    
    // This single rule block securely handles all access to 'documents' collections.
    match /{path=**}/documents/{documentId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
    
    // This single rule block securely handles all access to 'inspections' collections.
    match /{path=**}/inspections/{inspectionId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
