
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Properties Collection
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.status != 'Deleted')
      );
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 3. Tenants Collection
    match /tenants/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.email == request.auth.token.email.lower()
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.email == request.auth.token.email.lower()
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 4. Repairs (Maintenance) Collection
    match /repairs/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 5. Documents Collection
    match /documents/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 6. Messages Collection
    match /messages/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
    }

    // 7. Contractors Collection
    match /contractors/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 8. Rent Payments
    match /rentPayments/{id} {
      allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    // 9. Expenses
    match /expenses/{id} {
      allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    // 10. Inspections & Screenings
    match /inspections/{id} {
      allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    match /screenings/{id} {
      allow read, write: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
    }
  }
}
