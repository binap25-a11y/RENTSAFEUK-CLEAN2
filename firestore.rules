rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER PROFILE
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // TOP-LEVEL COLLECTIONS
    match /properties/{propertyId} {
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if resource.data.ownerId == request.auth.uid;
    }

    // GENERIC RULE FOR ALL SUB-COLLECTIONS OF A PROPERTY
    // This single rule covers maintenanceLogs, inspections, documents, expenses, etc.
    // It allows read and write access to any sub-collection document
    // if the user is the owner of the parent property document.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // SUB-COLLECTION for tenants
    match /tenants/{tenantId}/screenings/{screeningId} {
      allow read, write: if get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
  }
}
