
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Group Rules (Authorized Discovery) ---
    // Rules are split into distinct allow blocks to ensure the Firestore query optimizer 
    // can statically verify authorization against specific query filters (e.g. email or userId).
    
    match /{path=**}/tenants/{tenantId} {
      // Resident discovery: match by authenticated email
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email.lower();
      
      // Landlord oversight: match by authenticated UID
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Standard document reads
      allow get: if isSignedIn() && (
        resource.data.email == request.auth.token.email.lower() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.senderId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceLogs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.reportedBy == request.auth.uid;
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.reportedBy == request.auth.uid
      );
    }

    // --- Hierarchical Rules (Standard Portfolio Access) ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
