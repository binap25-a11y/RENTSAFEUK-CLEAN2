
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance
     * Optimized for high-speed identity discovery and verified Resident Hub access.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function authEmail() {
      return request.auth.token.get('email', '').lower();
    }

    // Landlord check: verifies if user owns the record or the parent property context
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '') || 
        request.auth.uid == data.get('userId', '')
      );
    }

    // Tenant check: establishes authorization via UID handshake or verified email registry
    function isTenant(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('tenantId', '') || 
        request.auth.uid == data.get('userId', '') ||
        request.auth.uid in data.get('activeTenantUids', []) ||
        (authEmail() != '' && authEmail() == data.get('email', '').lower()) ||
        (authEmail() != '' && authEmail() == data.get('tenantEmail', '').lower()) ||
        (authEmail() != '' && authEmail() in data.get('tenantEmails', []))
      );
    }

    // General authorization check for relational records
    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      allow get: if isRelated(resource.data);
      allow list: if isSignedIn(); // QAP: Search results are restricted by resource data checks
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      allow get: if isRelated(resource.data);
      allow list: if isSignedIn(); // QAP: Registry discovery is performed via explicit filters
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'tenantEmail', 'tenantEmails']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Repairs & Shared Ledgers ---
    match /repairs/{id} {
      allow get: if isRelated(resource.data);
      allow list: if isSignedIn(); // QAP
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.landlordId || request.auth.uid == resource.data.tenantId);
      allow list: if isSignedIn(); // QAP
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    // --- Generic Catch-all for App Services ---
    match /{path=**} {
      allow read, write: if isSignedIn() && (
        (resource != null && isLandlord(resource.data)) ||
        (request.resource != null && isLandlord(request.resource.data))
      );
    }
  }
}
