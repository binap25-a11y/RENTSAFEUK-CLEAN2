rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Profile ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Top-level Collections ---
    match /properties/{propertyId} {
      // Only the owner can read, create, update, or delete their property.
      // The `read` rule covers both `get` and `list` operations.
      // Client-side queries MUST include `where('ownerId', '==', request.auth.uid)`.
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /tenants/{tenantId} {
      // Only the owner can read their tenant records.
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /contractors/{contractorId} {
      // Only the owner can read their contractor records.
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Subcollection Rules for direct path access ---
    match /properties/{propertyId}/{subcollection}/{docId} {
      // All access requires checking ownership of the parent property.
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // This rule applies to all subcollections under a tenant.
    match /tenants/{tenantId}/{subcollection}/{docId} {
      // All access requires checking ownership of the parent tenant document.
      allow read, write: if get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
  }
}
