
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL SECURITY HELPERS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Helper to get normalized email from token.
     * Enforces lowercase for consistent security matching.
     */
    function getAuthEmail() {
      return request.auth.token.email.lower();
    }

    // --- COLLECTION GROUP RULES (CRITICAL) ---
    // These must be defined outside nested paths to allow global identity discovery.

    /**
     * @description Allows tenants to discover their own record across any user profile.
     * Requires the query to be filtered by email matching the user's token.
     */
    match /{path=**}/tenants/{tenantId} {
      allow list: if isSignedIn() && request.auth.token.email != null && resource.data.email.lower() == getAuthEmail();
      allow get: if isSignedIn() && request.auth.token.email != null && resource.data.email.lower() == getAuthEmail();
    }

    /**
     * @description Shared access for communications and maintenance logs.
     */
    match /{path=**}/messages/{messageId} {
       allow read, write: if isSignedIn();
    }
    
    match /{path=**}/maintenanceLogs/{logId} {
       allow list, get: if isSignedIn();
       allow create: if isSignedIn();
    }

    // --- CORE DATA HIERARCHY ---

    /**
     * @description Rules for user-specific data under the userProfiles root.
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      /**
       * @description Property management rules.
       */
      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Tenants can read their assigned property details for portal context.
        allow get: if isSignedIn();

        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
          // Individual document access for the tenant themselves.
          allow get: if isSignedIn() && resource.data.email.lower() == getAuthEmail();

          match /messages/{messageId} {
             allow read, write: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == getAuthEmail());
          }

          match /screenings/{screeningId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == getAuthEmail();
          }
          
          match /checklists/{checklistId} {
             allow read, write: if isOwner(userId);
             allow get: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(userId)/properties/$(propertyId)/tenants/$(tenantId)).data.email.lower() == getAuthEmail();
          }
        }

        match /maintenanceLogs/{logId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn();
          allow get, list: if isSignedIn();
        }

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }

        match /expenses/{expenseId} {
          allow read, write: if isOwner(userId);
        }

        match /rentPayments/{paymentId} {
          allow read, write: if isOwner(userId);
        }

        match /documents/{documentId} {
          allow read, write: if isOwner(userId);
          allow get: if isSignedIn();
        }
      }

      match /contractors/{contractorId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
