rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check ownership on a document by ownerId field
    function isOwner(doc) {
      return isSignedIn() && doc.ownerId == request.auth.uid;
    }

    // A user can manage their own profile document
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // A user can manage properties they own
    match /properties/{propertyId} {
      allow get: if isOwner(resource.data);
      // List queries are secured by client-side filtering and the `get` rule check on each document
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // A user can manage tenants they own
    match /tenants/{tenantId} {
      allow get: if isOwner(resource.data);
       // List queries are secured by client-side filtering and the `get` rule check on each document
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }
    
    // Subcollection: maintenanceLogs
    match /properties/{propertyId}/maintenanceLogs/{logId} {
      allow get: if isOwner(resource.data);
      allow list: if isSignedIn(); // Allows collection group query to run
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // Subcollection: inspections
    match /properties/{propertyId}/inspections/{inspectionId} {
      allow get: if isOwner(resource.data);
      allow list: if isSignedIn(); // Allows collection group query to run
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // Subcollection: documents
    match /properties/{propertyId}/documents/{documentId} {
      allow get: if isOwner(resource.data);
      allow list: if isSignedIn(); // Allows collection group query to run
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // Subcollection: expenses
    match /properties/{propertyId}/expenses/{expenseId} {
      allow get: if isOwner(resource.data);
      allow list: if isSignedIn(); // Allows collection group query to run
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // Subcollection: rentPayments
    match /properties/{propertyId}/rentPayments/{paymentId} {
      allow get: if isOwner(resource.data);
      allow list: if isSignedIn(); // Allows collection group query to run
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isOwner(resource.data);
    }
  }
}
