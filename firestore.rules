rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER PROFILE
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // SECURITY MODEL FOR USER-OWNED COLLECTIONS
    // For collections like 'properties', 'tenants', and 'contractors', the 'list'
    // rule allows any authenticated user to issue a query. Security is enforced
    // by the 'get' rule, which Firestore applies to every document returned by a query.
    // This means client-side queries MUST include a `where('ownerId', '==', request.auth.uid)`
    // clause. If a query is not specific enough and returns documents not owned by the
    // user, the entire request will fail with a 'permission denied' error.

    // PROPERTIES & SUBCOLLECTIONS
    match /properties/{propertyId} {
      allow get: if request.auth.uid == resource.data.ownerId;
      allow list: if request.auth.uid != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId;

      match /maintenanceLogs/{logId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
      match /inspections/{inspectionId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
      match /documents/{documentId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
       match /expenses/{expenseId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
       match /rentPayments/{rentPaymentId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
      match /checklists/{checklistId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
    }

    // TENANTS & SUBCOLLECTIONS
    match /tenants/{tenantId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
      allow list: if request.auth.uid != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      
      match /screenings/{screeningId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list: if request.auth.uid != null;
        allow create: if request.auth.uid == request.resource.data.ownerId;
      }
    }

    // CONTRACTORS
    match /contractors/{contractorId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
      allow list: if request.auth.uid != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
    }
  }
}
