rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly check for data ownership to support filtered queries
    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      // Use explicit get and list rules for better query authorization
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && (request.query.limit <= 500 && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);

      match /{allSubcollections=**} {
        allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
        allow list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
        allow write: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || (resource != null && resource.data.ownerId == request.auth.uid));
      }
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && (request.query.limit <= 500 && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
        allow write: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || (resource != null && resource.data.ownerId == request.auth.uid));
      }
    }

    match /contractors/{contractorId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && (request.query.limit <= 500 && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
  }
}