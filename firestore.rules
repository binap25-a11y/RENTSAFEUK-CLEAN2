
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MAINTAIN UK - SECURITY RULES DOCUMENTATION
     *
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model. The application is designed such that 
     * every piece of data (Properties, Tenants, Maintenance Requests, etc.) is explicitly owned 
     * by a UserProfile. Access is restricted to the authenticated owner.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isValidOwnership(field, userId) {
      return request.resource.data[field] == userId;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnership('id', userId);
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/properties/{propertyId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnership('ownerId', userId);
      allow update: if isExistingOwner(userId) && isImmutable('ownerId');
      allow delete: if isExistingOwner(userId);

      match /tenants/{tenantId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership('propertyOwnerId', userId);
        allow update: if isExistingOwner(userId) && isImmutable('propertyOwnerId');
        allow delete: if isExistingOwner(userId);
      }

      match /maintenanceRequests/{requestId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership('propertyOwnerId', userId);
        allow update: if isExistingOwner(userId) && isImmutable('propertyOwnerId');
        allow delete: if isExistingOwner(userId);
      }

      match /inspections/{inspectionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership('propertyOwnerId', userId);
        allow update: if isExistingOwner(userId) && isImmutable('propertyOwnerId');
        allow delete: if isExistingOwner(userId);
      }

      match /documents/{docId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOwnership('propertyOwnerId', userId);
        allow update: if isExistingOwner(userId) && isImmutable('propertyOwnerId');
        allow delete: if isExistingOwner(userId);
      }
    }

    match /users/{userId}/activityLogs/{logId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnership('userId', userId);
      allow update, delete: if false;
    }

    /**
     * @description Secure chat between residents and landlords.
     * @path /messages/{messageId}
     */
    match /messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
