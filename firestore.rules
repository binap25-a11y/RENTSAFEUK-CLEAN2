rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RentSafeUK Security Governance v11.0
     * Optimized for high-speed Resident Hub discovery and robust identity handshake.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Landlord check: verifies if user owns the record
    function isLandlord(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('landlordId', '')
      );
    }

    // Tenant check: authorizes access via UID or verified email handshake.
    // Note: We use direct string comparisons for optimal query compatibility.
    function isTenant(data) {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      return isSignedIn() && (
        uid == data.get('tenantId', '') || 
        uid == data.get('userId', '') ||
        uid in data.get('activeTenantUids', []) ||
        (email != null && (
          email == data.get('email', '') || 
          email == data.get('tenantEmail', '') || 
          email in data.get('tenantEmails', [])
        ))
      );
    }

    function isRelated(data) {
      return isLandlord(data) || isTenant(data);
    }

    // --- Identity Registry ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Registry ---
    match /tenants/{tenantId} {
      // IDENTITY DISCOVERY: Allow signed-in users to search for their own tenancy record.
      // We allow listing so discovery queries (by email or UID) can resolve.
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow residents to link their UID if their email matches.
      // Verified residents can update identity-linking fields to complete verification.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Property Portfolio ---
    match /properties/{propertyId} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      // HANDSHAKE: Allow verified residents to link their account to the property record.
      // This is critical for establishing the secure bridge on first portal login.
      allow update: if isSignedIn() && (
        isLandlord(resource.data) || 
        (isTenant(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId', 'activeTenantUids', 'status']))
      );
      allow delete: if isLandlord(resource.data);
    }

    // --- Shared Ledger Collections ---
    
    match /repairs/{id} {
      allow list: if isSignedIn();
      allow get: if isRelated(resource.data);
      allow create: if isSignedIn();
      allow update: if isRelated(resource.data);
      allow delete: if isLandlord(resource.data);
    }

    match /messages/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || isRelated(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /inspections/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /rentPayments/{id} {
      allow list: if isSignedIn();
      allow read: if isRelated(resource.data);
      allow write: if isLandlord(resource.data);
    }

    match /contractors/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }

    match /expenses/{id} {
      allow list: if isSignedIn();
      allow read, write: if isLandlord(resource.data) || (request.resource != null && isLandlord(request.resource.data));
    }
    
    // Explicit deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}