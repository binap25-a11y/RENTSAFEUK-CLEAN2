rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER PROFILE
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // SECURITY MODEL FOR USER-OWNED COLLECTIONS
    // For collections like 'properties', 'tenants', and 'contractors', security is
    // enforced by checking the 'ownerId' field on documents.
    //
    // The 'list' operation is permitted for any authenticated user, but queries MUST
    // include a `where('ownerId', '==', request.auth.uid)` clause. If a query
    // doesn't filter by ownerId, it will be rejected by the 'get' rule on the results.
    //
    // The 'create' operation requires the new document's 'ownerId' to match the
    // authenticated user's UID.

    // PROPERTIES & SUBCOLLECTIONS
    match /properties/{propertyId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;

      // Sub-collection rules remain nested for now.
      // These rules trust the client to set the correct ownerId on sub-collection documents.
      match /maintenanceLogs/{logId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
      match /inspections/{inspectionId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
      match /documents/{documentId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
       match /expenses/{expenseId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
       match /rentPayments/{rentPaymentId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
      match /checklists/{checklistId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
    }
    match /properties {
      allow list: if request.auth.uid != null;
      allow create: if request.auth.uid != null && request.resource.data.ownerId == request.auth.uid;
    }


    // TENANTS & SUBCOLLECTIONS
    match /tenants/{tenantId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
      
      match /screenings/{screeningId} {
        allow get, update, delete: if request.auth.uid == resource.data.ownerId;
        allow list, create: if request.auth.uid != null;
      }
    }
    match /tenants {
       allow list: if request.auth.uid != null;
       allow create: if request.auth.uid != null && request.resource.data.ownerId == request.auth.uid;
    }

    // CONTRACTORS
    match /contractors/{contractorId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }
    match /contractors {
      allow list: if request.auth.uid != null;
      allow create: if request.auth.uid != null && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
