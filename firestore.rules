rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANDLORD PROPERTY MANAGEMENT SECURITY MODEL
     * 
     * Core Philosophy:
     * This ruleset enforces a strict User-Ownership model. All application data is 
     * nested under a specific user's path (/users/{ownerId}/...), ensuring that 
     * authorization is derived directly from the URL path.
     * 
     * Data Structure:
     * The hierarchy is rooted at /users/{ownerId}. Subcollections include 'properties',
     * 'tenants', and 'documents'. Further nesting (e.g., 'tenancies' under 'properties')
     * maintains this ownership chain.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: We compare the {ownerId} in the document path 
     *    directly against the authenticated user's UID (request.auth.uid). This 
     *    eliminates the need for expensive get() calls in rules.
     * 2. Collection Group Queries: By organizing tenants under a user-scoped 
     *    collection, we resolve common permission issues with collectionGroup queries 
     *    while maintaining strict privacy between different landlords.
     * 3. Structural Segregation: Different entities (Properties, Tenants, Documents) 
     *    are kept in distinct subcollections to ensure that security logic remains 
     *    atomic and easy to debug.
     * 4. Relational Integrity: On creation, we enforce that internal 'id' fields 
     *    match the document ID in the path to prevent data mismatches.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Verifies ownership and existence for destructive operations (update/delete).
     * This ensures you can't attempt to modify a document that doesn't exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the 'id' field in the incoming data matches the document ID in the path.
     * Used during creation to ensure relational consistency.
     */
    function isDataConsistent(id) {
      return request.resource.data.id == id;
    }

    /**
     * Ensures that critical relational fields (like the entity ID) cannot be changed after creation.
     */
    function isRelationalFieldImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // --- Rules ---

    /**
     * @description Rules for the user's root document.
     * @path /users/{userId}
     * @allow (create) If the user's UID matches the document ID.
     * @deny (create) If a user tries to create a document for another UID.
     * @principle Pattern 4: Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for rental properties managed by a landlord.
       * @path /users/{userId}/properties/{propertyId}
       * @allow (create) Owner creating a property with matching internal ID.
       * @deny (list) Anonymous users or mismatched userId.
       * @principle Pattern 1: Ownership.
       */
      match /properties/{propertyId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isDataConsistent(propertyId);
        allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for tenancy agreements associated with a specific property.
         * @path /users/{userId}/properties/{propertyId}/tenancies/{tenancyId}
         * @allow (get) Owner of the parent property accessing the tenancy.
         * @deny (update) Attempting to change the tenancy ID.
         * @principle Pattern 1: Ownership (Inherited from path).
         */
        match /tenancies/{tenancyId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent(tenancyId);
          allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for maintenance requests for a property.
         * @path /users/{userId}/properties/{propertyId}/maintenanceRequests/{maintenanceRequestId}
         * @allow (list) Owner viewing all requests for their property.
         * @principle Pattern 1: Ownership (Inherited from path).
         */
        match /maintenanceRequests/{maintenanceRequestId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent(maintenanceRequestId);
          allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for property inspections.
         * @path /users/{userId}/properties/{propertyId}/inspections/{inspectionId}
         * @allow (create) Owner scheduling a new inspection.
         * @principle Pattern 1: Ownership (Inherited from path).
         */
        match /inspections/{inspectionId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent(inspectionId);
          allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Master records for tenants managed by the landlord.
       * @path /users/{userId}/tenants/{tenantId}
       * @allow (list) Owner listing all their tenants directly.
       * @deny (list) Collection Group queries across all users.
       * @principle Pattern 1: Ownership. Resolves collectionGroup query issues by scoping to user path.
       */
      match /tenants/{tenantId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isDataConsistent(tenantId);
        allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for digital documents (images, PDFs) owned by the user.
       * @path /users/{userId}/documents/{documentId}
       * @allow (create) Owner uploading a new document record.
       * @principle Pattern 1: Ownership. Centralizes files for easy listing.
       */
      match /documents/{documentId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isDataConsistent(documentId);
        allow update: if isExistingOwner(userId) && isRelationalFieldImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Explicit denial for collection group queries on tenants to prevent data leaks.
     * This forces the application to use the user-scoped tenant paths defined above.
     */
    match /{path=**}/tenants/{tenantId} {
      allow read, write: if false;
    }
  }
}