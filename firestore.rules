
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTSAFEUK SECURITY GOVERNANCE v20.0
     * Optimized for Static Query Prove-ability and Actor-Based Authorization.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return isSignedIn() && "email" in request.auth.token ? request.auth.token.email.lower() : "";
    }

    // --- User & Resident Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /residents/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Properties Registry ---
    match /properties/{propertyId} {
      // STATICALLY PROVABLE LIST: Evaluates specific filter paths
      allow list: if isSignedIn() && (
        (request.query.filters.landlordId == [request.auth.uid]) ||
        (request.auth.uid in request.query.filters.activeTenantUids) ||
        (userEmail() != "" && request.query.filters.tenantEmail == [userEmail()]) ||
        (userEmail() != "" && userEmail() in request.query.filters.tenantEmails)
      );
      
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.uid in resource.data.get("activeTenantUids", []) ||
        resource.data.get("tenantEmail", "").lower() == userEmail() ||
        userEmail() in resource.data.get("tenantEmails", [])
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes residents to link UID on first login
        (userEmail() != "" && resource.data.get("tenantEmail", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tenantId', 'activeTenantUids', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Tenants Registry ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && (
        (request.query.filters.landlordId == [request.auth.uid]) ||
        (request.query.filters.userId == [request.auth.uid]) ||
        (userEmail() != "" && request.query.filters.email == [userEmail()])
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.get("userId", "") == request.auth.uid ||
        resource.data.get("email", "").lower() == userEmail()
      );
      
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        // HANDSHAKE BRIDGE: Authorizes verified UID mapping
        (userEmail() != "" && resource.data.get("email", "").lower() == userEmail() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'verified', 'joinedDate', 'status', 'lastSyncCheck']))
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- Maintenance (Repairs) ---
    match /repairs/{repairId} {
      allow list: if isSignedIn() && (
        (request.query.filters.landlordId == [request.auth.uid]) ||
        (request.query.filters.tenantId == [request.auth.uid]) ||
        (request.query.filters.reportedBy == [request.auth.uid])
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        resource.data.get('reportedBy', '') == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.get("reportedBy", "") == request.auth.uid
      );
    }

    // --- Communication (Messages) ---
    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        (request.query.filters.tenantId == [request.auth.uid]) ||
        (request.query.filters.landlordId == [request.auth.uid])
      );
      
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // --- Documents ---
    match /documents/{id} {
      allow list: if isSignedIn() && (
        (request.query.filters.landlordId == [request.auth.uid]) ||
        ('propertyId' in request.query.filters)
      );
      
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.landlordId == request.auth.uid ||
        isSignedIn()
      );
      
      allow create, update, delete: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- Financial Ledger ---
    match /rentPayments/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    
    match /expenses/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }

    // --- General Audits ---
    match /contractors/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /inspections/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /screenings/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
    match /checklists/{id} {
      allow list: if isSignedIn() && (request.query.filters.landlordId == [request.auth.uid]);
      allow read, write: if isSignedIn() && (resource == null || resource.data.landlordId == request.auth.uid);
    }
  }
}
