rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- User Profile ---
    // Users can only read and write their own document.
    match /users/{userId} {
      allow read, update, create: if request.auth.uid == userId;
    }

    // --- Properties Collection ---
    match /properties {
      // Anyone authenticated can create a property, as long as they set themselves as the owner.
      allow create: if request.auth.uid == request.resource.data.ownerId;
      // Anyone authenticated can query the collection, but client-side must filter by ownerId.
      allow list: if request.auth.uid != null;
    }

    // --- Single Property Document ---
    match /properties/{propertyId} {
      // Only the owner can get, update, or delete their property document.
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }

    // --- Tenants Collection ---
    match /tenants {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid != null;
    }

    // --- Single Tenant Document ---
    match /tenants/{tenantId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }

    // --- Contractors Collection ---
    match /contractors {
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow list: if request.auth.uid != null;
    }

    // --- Single Contractor Document ---
    match /contractors/{contractorId} {
      allow get, update, delete: if request.auth.uid == resource.data.ownerId;
    }

    // --- Generic Sub-Collection Rules ---

    // This rule applies to ALL sub-collections under any property.
    // It allows read/write access only if the user owns the parent property document.
    match /properties/{propertyId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // This rule applies to ALL sub-collections under any tenant.
    // It allows read/write access only if the user owns the parent tenant document.
    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow read, write: if get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
  }
}
